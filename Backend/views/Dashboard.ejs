      <div class="confirm-modal-actions">
        <button class="confirm-btn confirm-btn-cancel" onclick="closeConfirm()">Keep it</button>
        <button class="confirm-btn confirm-btn-danger" id="confirmActionBtn">Yes, cancel</button>
