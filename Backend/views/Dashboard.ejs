<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ride मित्र — My Dashboard</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Rozha+One&family=Noto+Sans+Devanagari:wght@700;900&display=swap"
    rel="stylesheet">
  <script src="/socket.io/socket.io.js" defer></script>

  <!-- Capture google_token immediately before any other JS runs -->
  <script>
    (function () {
      const p = new URLSearchParams(window.location.search);
      const gt = p.get("google_token");
      if (gt) {
        localStorage.setItem("token", gt);
        window.history.replaceState({}, "", window.location.pathname);
      }
    })();
  </script>
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #FAFAF8;
      --surface: #FFFFFF;
      --surface2: #F5F3EE;
      --border: #E8E5DF;
      --accent: #FF8C00;
      --accent2: #E07000;
      --green: #2ECC71;
      --red: #E74C3C;
      --yellow: #F39C12;
      --text: #1A1A2E;
      --muted: #8A8A9A;
      --card-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
      --card-shadow-hover: 0 8px 32px rgba(0, 0, 0, 0.11);
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      display: flex;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── Sidebar ── */
    .sidebar {
      width: 240px;
      min-height: 100vh;
      background: rgba(255, 255, 255, 0.82);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      padding: 28px 0;
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      z-index: 100;
      box-shadow: 2px 0 24px rgba(0, 0, 0, 0.04);
    }

    /* UPDATED LOGO STYLE */
    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0 24px 32px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 20px;
      color: var(--text);
      letter-spacing: -0.3px;
    }

    .logo .hindi {
      font-family: 'Rozha One', 'Noto Sans Devanagari', serif;
      font-weight: 900;
      color: var(--accent);
    }

    .logo-icon {
      width: 36px;
      height: 36px;
      background: linear-gradient(135deg, var(--accent), #FF6B00);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      box-shadow: 0 4px 12px rgba(255, 140, 0, 0.3);
    }

    .nav-section {
      padding: 0 12px;
      margin-bottom: 24px;
    }

    .nav-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1.5px;
      color: var(--muted);
      text-transform: uppercase;
      padding: 0 12px 10px;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.2s;
      font-size: 14px;
      color: var(--muted);
      font-weight: 500;
      margin-bottom: 2px;
      text-decoration: none;
    }

    .nav-item:hover {
      background: var(--surface2);
      color: var(--text);
    }

    .nav-item.active {
      background: linear-gradient(90deg, rgba(255, 140, 0, 0.12), rgba(255, 140, 0, 0.05));
      color: var(--accent);
      border: 1px solid rgba(255, 140, 0, 0.2);
      font-weight: 600;
    }

    .nav-item .icon {
      font-size: 16px;
      width: 20px;
      text-align: center;
    }

    .badge {
      margin-left: auto;
      background: var(--accent);
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: 20px;
    }

    .sidebar-cta {
      margin: 0 12px 24px;
    }

    .cta-btn-sidebar {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      padding: 12px 16px;
      border-radius: 14px;
      border: none;
      background: linear-gradient(135deg, var(--accent), #FF6B00);
      color: #fff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.15s;
      box-shadow: 0 4px 20px rgba(255, 140, 0, 0.35);
      letter-spacing: 0.3px;
    }

    .cta-btn-sidebar:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }

    .cta-btn-sidebar:active {
      transform: translateY(0);
    }

    .sidebar-bottom {
      margin-top: auto;
      padding: 0 12px;
    }

    .user-card {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      background: var(--surface2);
      border-radius: 14px;
      border: 1px solid var(--border);
      box-shadow: var(--card-shadow);
    }

    .avatar {
      width: 36px;
      height: 36px;
      background: linear-gradient(135deg, var(--accent), #FF6B00);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 13px;
      color: #fff;
    }

    .user-info {
      flex: 1;
    }

    .user-name {
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
    }

    .user-role {
      font-size: 11px;
      color: var(--muted);
    }

    /* ── Main ── */
    .main {
      margin-left: 240px;
      flex: 1;
      padding: 32px;
      max-width: calc(100vw - 240px);
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 36px;
    }

    .page-title {
      font-family: 'Rozha One', serif;
      font-size: 28px;
      font-weight: 400;
      color: var(--text);
      letter-spacing: 0.3px;
    }

    .breadcrumb {
      font-size: 12px;
      color: var(--muted);
      margin-top: 2px;
      font-weight: 500;
    }

    .breadcrumb span {
      color: var(--accent);
      font-weight: 600;
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .search-box {
      display: flex;
      align-items: center;
      gap: 8px;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 9px 14px;
      font-size: 13px;
      color: var(--muted);
      width: 220px;
      box-shadow: var(--card-shadow);
    }

    .notif-btn {
      width: 40px;
      height: 40px;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      border: 1px solid var(--border);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      position: relative;
      font-size: 16px;
      box-shadow: var(--card-shadow);
    }

    .notif-dot {
      position: absolute;
      top: 8px;
      right: 8px;
      width: 7px;
      height: 7px;
      background: var(--red);
      border-radius: 50%;
      border: 1px solid var(--bg);
    }

    /* ── Greeting Banner ── */
    .greeting-banner {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 28px 32px;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: relative;
      overflow: hidden;
      animation: fadeUp 0.5s ease both;
      box-shadow: var(--card-shadow);
    }

    .greeting-banner::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, rgba(255, 140, 0, 0.06) 0%, rgba(255, 107, 0, 0.03) 50%, transparent 80%);
      pointer-events: none;
    }

    .greeting-bg-blob {
      position: absolute;
      right: -60px;
      top: -60px;
      width: 260px;
      height: 260px;
      background: radial-gradient(circle, rgba(255, 140, 0, 0.1), transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    .greeting-text .hello {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 4px;
      font-weight: 500;
    }

    .greeting-text h2 {
      font-family: 'Rozha One', serif;
      font-size: 24px;
      font-weight: 400;
      margin-bottom: 6px;
      color: var(--text);
      letter-spacing: 0.3px;
    }

    .greeting-text p {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
      font-weight: 400;
    }

    .greeting-stats {
      display: flex;
      gap: 32px;
      position: relative;
      z-index: 1;
    }

    .greet-stat {
      text-align: center;
    }

    .greet-stat-val {
      font-family: 'Rozha One', serif;
      font-size: 24px;
      font-weight: 400;
      margin-bottom: 2px;
    }

    .greet-stat-label {
      font-size: 11px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
    }

    .greet-divider {
      width: 1px;
      background: var(--border);
      height: 40px;
      align-self: center;
    }

    /* ── Action Cards Grid ── */
    .action-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 24px;
    }

    .action-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 32px;
      position: relative;
      overflow: hidden;
      transition: transform 0.22s, box-shadow 0.22s, border-color 0.2s;
      animation: fadeUp 0.5s ease both;
      box-shadow: var(--card-shadow);
    }

    .action-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--card-shadow-hover);
    }

    .action-card.search-card {
      animation-delay: 0.1s;
    }

    .action-card.sell-card {
      animation-delay: 0.18s;
    }

    .action-card.search-card:hover {
      border-color: rgba(255, 140, 0, 0.35);
    }

    .action-card.sell-card:hover {
      border-color: rgba(46, 204, 113, 0.35);
    }

    .action-card.search-card::before {
      content: '';
      position: absolute;
      right: -40px;
      bottom: -40px;
      width: 200px;
      height: 200px;
      background: radial-gradient(circle, rgba(255, 140, 0, 0.08), transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    .action-card.sell-card::before {
      content: '';
      position: absolute;
      right: -40px;
      bottom: -40px;
      width: 200px;
      height: 200px;
      background: radial-gradient(circle, rgba(46, 204, 113, 0.08), transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    .action-card-icon {
      width: 52px;
      height: 52px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      margin-bottom: 20px;
    }

    .search-card .action-card-icon {
      background: rgba(255, 140, 0, 0.1);
    }

    .sell-card .action-card-icon {
      background: rgba(46, 204, 113, 0.1);
    }

    .action-card-title {
      font-family: 'Rozha One', serif;
      font-size: 22px;
      font-weight: 400;
      margin-bottom: 6px;
      color: var(--text);
      letter-spacing: 0.3px;
      line-height: 1.4;
    }

    .action-card-sub {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 24px;
      font-weight: 400;
    }

    .search-row {
      display: flex;
      gap: 10px;
      align-items: stretch;
    }

    .ride-input-wrap {
      flex: 1;
      position: relative;
    }

    .ride-input-wrap .input-icon {
      position: absolute;
      left: 13px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 14px;
      color: var(--muted);
      pointer-events: none;
    }

    .ride-input {
      width: 100%;
      background: var(--surface2);
      border: 1.5px solid var(--border);
      border-radius: 12px;
      padding: 12px 14px 12px 38px;
      color: var(--text);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .ride-input::placeholder {
      color: var(--muted);
    }

    .ride-input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(255, 140, 0, 0.12);
    }

    .btn-search {
      padding: 12px 22px;
      border-radius: 12px;
      border: none;
      background: linear-gradient(135deg, var(--accent), #FF6B00);
      color: #fff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.15s;
      white-space: nowrap;
      box-shadow: 0 4px 16px rgba(255, 140, 0, 0.3);
    }

    .btn-search:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }

    .btn-search:active {
      transform: translateY(0);
    }

    .quick-chips {
      display: flex;
      gap: 8px;
      margin-top: 14px;
      flex-wrap: wrap;
    }

    .chip {
      font-size: 12px;
      color: var(--muted);
      background: var(--surface2);
      border: 1.5px solid var(--border);
      padding: 5px 12px;
      border-radius: 20px;
      cursor: pointer;
      transition: all 0.2s;
      font-weight: 500;
    }

    .chip:hover {
      color: var(--accent);
      border-color: rgba(255, 140, 0, 0.4);
      background: rgba(255, 140, 0, 0.05);
    }

    .feature-pills {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 24px;
    }

    .feature-pill {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: var(--muted);
      font-weight: 400;
    }

    .feature-pill-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--green);
      flex-shrink: 0;
    }

    .btn-post {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 28px;
      border-radius: 14px;
      border: none;
      background: linear-gradient(135deg, var(--green), #27AE60);
      color: #fff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.15s;
      box-shadow: 0 4px 20px rgba(46, 204, 113, 0.3);
      letter-spacing: 0.3px;
    }

    .btn-post:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }

    .btn-post:active {
      transform: translateY(0);
    }

    /* ── Recent Rides Table ── */
    .table-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 24px;
      animation: fadeUp 0.5s ease 0.3s both;
      box-shadow: var(--card-shadow);
    }

    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 22px;
    }

    .card-title {
      font-family: 'Rozha One', serif;
      font-weight: 400;
      font-size: 17px;
      color: var(--text);
      letter-spacing: 0.2px;
    }

    .card-sub {
      font-size: 11px;
      color: var(--muted);
      margin-top: 3px;
      font-weight: 500;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th {
      font-size: 11px;
      color: var(--muted);
      font-weight: 700;
      text-align: left;
      padding: 0 0 12px;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      border-bottom: 1.5px solid var(--border);
    }

    td {
      padding: 12px 0;
      font-size: 13px;
      border-bottom: 1px solid rgba(232, 229, 223, 0.7);
      vertical-align: middle;
    }

    tr:last-child td {
      border-bottom: none;
    }

    .rider-info {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .rider-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 700;
      flex-shrink: 0;
      color: #fff;
    }

    .rider-name {
      font-weight: 600;
      font-size: 13px;
      color: var(--text);
    }

    .rider-id {
      font-size: 11px;
      color: var(--muted);
      font-weight: 500;
    }

    .status-badge {
      font-size: 11px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 20px;
      display: inline-block;
      letter-spacing: 0.2px;
    }

    .status-active {
      background: rgba(46, 204, 113, 0.1);
      color: #27AE60;
    }

    .status-pending {
      background: rgba(243, 156, 18, 0.12);
      color: #E67E22;
    }

    .status-completed {
      background: rgba(255, 140, 0, 0.1);
      color: var(--accent);
    }

    .status-cancelled {
      background: rgba(231, 76, 60, 0.1);
      color: var(--red);
    }

    .stars {
      color: var(--yellow);
      font-size: 11px;
      letter-spacing: 1px;
    }

    /* ── Profile Snapshot ── */
    .profile-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 28px;
      animation: fadeUp 0.5s ease 0.3s both;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      box-shadow: var(--card-shadow);
    }

    .profile-avatar-lg {
      width: 72px;
      height: 72px;
      background: linear-gradient(135deg, var(--accent), #FF6B00);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 22px;
      margin-bottom: 14px;
      box-shadow: 0 0 0 5px rgba(255, 140, 0, 0.12), 0 4px 20px rgba(255, 140, 0, 0.2);
      color: #fff;
    }

    .profile-name {
      font-family: 'Rozha One', serif;
      font-size: 20px;
      font-weight: 400;
      margin-bottom: 3px;
      color: var(--text);
      letter-spacing: 0.3px;
    }

    .profile-email {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 20px;
      font-weight: 500;
    }

    .profile-stats {
      display: flex;
      gap: 0;
      width: 100%;
      border: 1.5px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 20px;
      background: var(--surface2);
    }

    .p-stat {
      flex: 1;
      padding: 14px 10px;
      text-align: center;
      border-right: 1.5px solid var(--border);
    }

    .p-stat:last-child {
      border-right: none;
    }

    .p-stat-val {
      font-family: 'Rozha One', serif;
      font-size: 20px;
      font-weight: 400;
      margin-bottom: 3px;
    }

    .p-stat-label {
      font-size: 10px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 700;
    }

    .btn-edit-profile {
      width: 100%;
      padding: 11px;
      border-radius: 12px;
      border: 1.5px solid var(--border);
      background: var(--surface2);
      color: var(--text);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s, color 0.2s;
    }

    .btn-edit-profile:hover {
      border-color: var(--accent);
      background: rgba(255, 140, 0, 0.05);
      color: var(--accent);
    }

    /* ── Layout helpers ── */
    .bottom-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(18px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes pulse {

      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(46, 204, 113, 0.5);
      }

      50% {
        box-shadow: 0 0 0 5px rgba(46, 204, 113, 0);
      }
    }

    /* ── Table enhancements ── */
    th {
      padding: 0 10px 12px;
    }

    th:first-child {
      padding-left: 0;
    }

    th:last-child {
      padding-right: 0;
    }

    td {
      padding: 11px 10px;
    }

    td:first-child {
      padding-left: 0;
    }

    td:last-child {
      padding-right: 0;
    }

    /* Ride group header inside Posted table */
    .ride-group-header {
      background: linear-gradient(90deg, rgba(255, 140, 0, 0.06), rgba(255, 140, 0, 0.02));
      border-top: 1px solid var(--border);
    }

    .ride-group-header td {
      font-size: 11px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 0.4px;
      padding: 8px 0 6px;
      border-bottom: none;
    }

    .ride-group-header:first-child {
      border-top: none;
    }

    /* No-booking placeholder row */
    .no-booking-row td {
      font-size: 12px;
      color: var(--muted);
      padding: 5px 0 12px;
      border-bottom: none;
      font-style: italic;
    }

    /* Empty state */
    .table-empty td {
      text-align: center;
      padding: 28px 0;
      color: var(--muted);
      font-size: 13px;
      border-bottom: none;
    }

    /* Route + date stacked cell */
    .route-cell .route-main {
      font-weight: 600;
      font-size: 13px;
      color: var(--text);
    }

    .route-cell .route-date {
      font-size: 11px;
      color: var(--muted);
      margin-top: 2px;
    }

    /* Fare × seats stacked cell */
    .fare-cell .fare-main {
      font-weight: 700;
      font-size: 13px;
      color: var(--text);
    }

    .fare-cell .fare-seats {
      font-size: 11px;
      color: var(--muted);
      margin-top: 2px;
    }

    /* ── Chat Modal ── */
    .chat-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.35);
      backdrop-filter: blur(4px);
      z-index: 9000;
      align-items: flex-end;
      justify-content: flex-end;
      padding: 32px;
    }

    .chat-overlay.open {
      display: flex;
    }

    .chat-modal {
      width: 380px;
      max-height: 560px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.18);
      display: flex;
      flex-direction: column;
      animation: fadeUp 0.28s ease both;
      overflow: hidden;
    }

    .chat-header {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 18px 20px;
      background: linear-gradient(135deg, var(--accent), #FF6B00);
      color: #fff;
      flex-shrink: 0;
    }

    .chat-header-info {
      flex: 1;
      min-width: 0;
    }

    .chat-header-title {
      font-weight: 700;
      font-size: 15px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .chat-header-sub {
      font-size: 11px;
      opacity: 0.85;
      margin-top: 1px;
    }

    .chat-close-btn {
      width: 30px;
      height: 30px;
      background: rgba(255, 255, 255, 0.2);
      border: none;
      border-radius: 50%;
      color: #fff;
      font-size: 16px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: background 0.2s;
    }

    .chat-close-btn:hover {
      background: rgba(255, 255, 255, 0.35);
    }

    .chat-body {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      min-height: 200px;
      max-height: 380px;
      background: var(--bg);
    }

    .chat-body::-webkit-scrollbar {
      width: 4px;
    }

    .chat-body::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 4px;
    }

    .chat-msg {
      max-width: 80%;
      padding: 9px 13px;
      border-radius: 18px;
      font-size: 13px;
      line-height: 1.5;
      word-break: break-word;
    }

    .chat-msg.mine {
      align-self: flex-end;
      background: linear-gradient(135deg, var(--accent), #FF6B00);
      color: #fff;
      border-bottom-right-radius: 4px;
    }

    .chat-msg.theirs {
      align-self: flex-start;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text);
      border-bottom-left-radius: 4px;
    }

    .chat-msg-meta {
      font-size: 10px;
      margin-top: 3px;
      opacity: 0.7;
    }

    .chat-empty {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      font-size: 13px;
      gap: 6px;
      padding: 24px 0;
    }

    .chat-locked {
      padding: 12px 16px;
      background: rgba(231, 76, 60, 0.07);
      border-top: 1px solid rgba(231, 76, 60, 0.15);
      font-size: 12px;
      color: var(--red);
      text-align: center;
      flex-shrink: 0;
    }

    .chat-footer {
      display: flex;
      gap: 8px;
      padding: 12px 16px;
      border-top: 1px solid var(--border);
      background: var(--surface);
      flex-shrink: 0;
    }

    .chat-input {
      flex: 1;
      background: var(--surface2);
      border: 1.5px solid var(--border);
      border-radius: 20px;
      padding: 9px 14px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      color: var(--text);
      outline: none;
      transition: border-color 0.2s;
    }

    .chat-input:focus {
      border-color: var(--accent);
    }

    .chat-input:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .chat-send-btn {
      width: 38px;
      height: 38px;
      background: linear-gradient(135deg, var(--accent), #FF6B00);
      border: none;
      border-radius: 50%;
      color: #fff;
      font-size: 16px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.2s, transform 0.15s;
      flex-shrink: 0;
    }

    .chat-send-btn:hover:not(:disabled) {
      opacity: 0.9;
      transform: scale(1.05);
    }

    .chat-send-btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .btn-contact {
      font-size: 11px;
      padding: 4px 10px;
      border-radius: 20px;
      border: 1.5px solid var(--accent);
      background: rgba(255, 140, 0, 0.08);
      color: var(--accent);
      cursor: pointer;
      font-weight: 600;
      transition: all 0.2s;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .btn-contact:hover {
      background: var(--accent);
      color: #fff;
    }

    /* ── Cancel / Danger Button ── */
    .btn-danger {
      font-size: 11px;
      padding: 4px 10px;
      border-radius: 20px;
      border: 1.5px solid var(--red);
      background: rgba(231, 76, 60, 0.08);
      color: var(--red);
      cursor: pointer;
      font-weight: 600;
      transition: all 0.2s;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .btn-danger:hover {
      background: var(--red);
      color: #fff;
    }

    /* ── Confirm Modal ── */
    .confirm-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      backdrop-filter: blur(6px);
      z-index: 9999;
      align-items: center;
      justify-content: center;
    }

    .confirm-overlay.open {
      display: flex;
    }

    .confirm-modal {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 36px 32px 28px;
      max-width: 400px;
      width: 90%;
      box-shadow: 0 24px 80px rgba(0,0,0,0.18);
      animation: fadeUp 0.25s ease both;
      text-align: center;
    }

    .confirm-modal-icon {
      font-size: 44px;
      margin-bottom: 16px;
    }

    .confirm-modal-title {
      font-family: 'Rozha One', serif;
      font-size: 20px;
      color: var(--text);
      margin-bottom: 8px;
    }

    .confirm-modal-body {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 28px;
    }

    .confirm-modal-actions {
      display: flex;
      gap: 12px;
      justify-content: center;
    }

    .confirm-btn {
      padding: 11px 28px;
      border-radius: 14px;
      border: none;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.15s;
    }

    .confirm-btn:hover { opacity: 0.88; transform: translateY(-1px); }
    .confirm-btn:active { transform: translateY(0); }

    .confirm-btn-cancel {
      background: var(--surface2);
      border: 1.5px solid var(--border);
      color: var(--text);
    }

    .confirm-btn-danger {
      background: linear-gradient(135deg, #E74C3C, #C0392B);
      color: #fff;
      box-shadow: 0 4px 16px rgba(231,76,60,0.3);
    }

    /* ── Toast ── */
    .toast {
      position: fixed;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%) translateY(80px);
      background: var(--text);
      color: #fff;
      padding: 12px 24px;
      border-radius: 40px;
      font-size: 13px;
      font-weight: 600;
      box-shadow: 0 8px 32px rgba(0,0,0,0.18);
      z-index: 10000;
      transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1), opacity 0.3s;
      opacity: 0;
      white-space: nowrap;
    }

    .toast.show {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }

    .toast.success { background: #27AE60; }
    .toast.error   { background: var(--red); }
  </style>
</head>

<body>

  <!-- ── Chat Modal ─────────────────────────────────────────────────────── -->
  <div class="chat-overlay" id="chatOverlay">
    <div class="chat-modal" id="chatModal">
      <div class="chat-header">
        <div
          style="width:38px;height:38px;background:rgba(255,255,255,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;">
          💬</div>
