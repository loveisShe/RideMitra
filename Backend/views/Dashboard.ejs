      </div>
      <div class="topbar-right">
        <div id="live-dot" title="Connecting..."
          style="width:8px;height:8px;border-radius:50%;background:#F39C12;flex-shrink:0;transition:background 0.4s;animation:pulse 2s infinite;">
        </div>
        <a href="/notifications">
          <div class="notif-btn">🔔<div class="notif-dot"></div>
          </div>
        </a>
        <div
          style="padding:8px 12px; background:rgba(255,255,255,0.9); backdrop-filter:blur(10px); border:1px solid var(--border); border-radius:10px; display:flex; gap:10px; align-items:center; box-shadow:var(--card-shadow);">
          <div class="avatar" id="top-avatar" style="width:30px;height:30px;font-size:11px;">--</div>
          <span id="top-name" style="font-size:13px; font-weight:600; color:var(--text);">Loading...</span>
