    <div class="bottom-row">

      <!-- LEFT: Posted Rides -->
      <div class="table-card">
        <div class="card-header">
          <div>
            <div class="card-title">Rides Posted</div>
            <div class="card-sub">Your created rides</div>
          </div>
        </div>

        <table>
          <thead>
            <tr>
              <th>Passenger</th>
              <th>Route</th>
              <th>Fare/Seat</th>
              <th>Seats</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="postedRidesTable"></tbody>
        </table>
      </div>

      <!-- RIGHT: Booked Rides -->
      <div class="table-card">
        <div class="card-header">
          <div>
            <div class="card-title">Rides Booked</div>
            <div class="card-sub">Your bookings</div>
          </div>
        </div>

        <table>
          <thead>
            <tr>
              <th>Driver</th>
              <th>Route</th>
              <th>Fare &amp; Seats</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="bookedRidesTable"></tbody>
        </table>
      </div>

    </div>

    <script>
      const token = (localStorage.getItem("token") || sessionStorage.getItem("token"));

      function statusBadge(status) {
        const map = {
          accepted: { cls: "status-active", label: "✅ Accepted" },
          rejected: { cls: "status-cancelled", label: "❌ Rejected" },
          pending: { cls: "status-pending", label: "⏳ Pending" }
        };
        const s = map[status] || { cls: "status-pending", label: status || "Pending" };
        return `<span class="status-badge ${s.cls}">${s.label}</span>`;
      }

      function fmtDate(d) {
        if (!d) return "—";
        return new Date(d).toLocaleDateString("en-IN", { day: "numeric", month: "short" });
      }

      // ================= POSTED RIDES (driver view) =================
      async function fetchPostedRides() {
        try {
          const res = await fetch("/api/v4/bookings/my-rides-with-passengers", {
            headers: { Authorization: `Bearer ${token}` }
          });
          const rides = await res.json();
          const tbody = document.getElementById("postedRidesTable");
          tbody.innerHTML = "";

          if (!Array.isArray(rides) || !rides.length) {
            tbody.innerHTML = `<tr class="table-empty"><td colspan="5">No rides posted yet — share your journey! 🚀</td></tr>`;
            return;
          }

          rides.forEach(ride => {
            const from = ride.pickup || '—';
            const to = ride.destination || '—';
            const fare = ride.fare != null ? ride.fare : '—';
            const seats = ride.seats != null ? ride.seats : '—';
            const rideEnd = ride.rideStatus === "completed" || ride.rideStatus === "cancelled";
            const canCancelRide = !rideEnd; // driver can cancel any non-ended ride

            const cancelRideBtn = canCancelRide
              ? `<button class="btn-danger" onclick="confirmCancelRide('${ride.id}','${from} → ${to}')">✕ Cancel Ride</button>`
              : '';

            tbody.innerHTML += `
        <tr class="ride-group-header">
          <td colspan="6">📍 ${from} → ${to} &nbsp;·&nbsp; ${fmtDate(ride.date)} &nbsp;·&nbsp; ₹${fare}/seat &nbsp;·&nbsp; ${seats} seats total &nbsp; ${cancelRideBtn}</td>
        </tr>`;

            if (!ride.bookings || !ride.bookings.length) {
              tbody.innerHTML += `<tr class="no-booking-row"><td colspan="6">No booking requests yet</td></tr>`;
            } else {
              ride.bookings.forEach(b => {
                const name = b.passengerName || 'Passenger';
                const initial = name.charAt(0).toUpperCase();
                const seatNum = b.seatsRequested || 1;
                const canChat = b.status === 'accepted' && !rideEnd;
                const contactBtn = canChat
                  ? `<button class="btn-contact" onclick="openChat('${b.bookingId}','${name}','${from} → ${to}')">💬 Chat</button>`
                  : '';
                tbody.innerHTML += `
            <tr>
              <td>
                <div class="rider-info">
                  <div class="rider-avatar" style="background:linear-gradient(135deg,var(--accent),#FF6B00)">${initial}</div>
                  <div><div class="rider-name">${name}</div></div>
                </div>
              </td>
              <td>${from} → ${to}</td>
              <td>₹${fare}</td>
              <td>${seatNum} seat${seatNum > 1 ? 's' : ''}</td>
              <td>${statusBadge(b.status)}</td>
              <td>${contactBtn}</td>
            </tr>`;
              });
            }
          });

        } catch (err) {
          console.error("Posted rides error:", err);
          document.getElementById("postedRidesTable").innerHTML =
            `<tr class="table-empty"><td colspan="5">Could not load rides. Is the server running?</td></tr>`;
        }
      }

      // ================= BOOKED RIDES (passenger view) =================
      async function fetchBookedRides() {
        try {
          const res = await fetch("/api/v4/bookings/my-bookings", {
            headers: { Authorization: `Bearer ${token}` }
          });
          const data = await res.json();
          const tbody = document.getElementById("bookedRidesTable");
          tbody.innerHTML = "";

          if (!Array.isArray(data) || !data.length) {
            tbody.innerHTML = `<tr class="table-empty"><td colspan="4">No bookings yet — find a ride to get started 🚗</td></tr>`;
            return;
          }

          data.forEach(b => {
            const driver = b.driverName || 'Driver';
            const initial = driver.charAt(0).toUpperCase();
            const seats = b.seatsRequested || 1;
            const rideEnd = b.rideStatus === 'completed' || b.rideStatus === 'cancelled';
            const canChat = b.status === 'accepted' && !rideEnd;
            const canCancel = (b.status === 'pending' || b.status === 'accepted') && !rideEnd;
            const route = `${b.pickup || '—'} → ${b.destination || '—'}`;
            const contactBtn = canChat
              ? `<button class="btn-contact" onclick="openChat('${b.bookingId}','${driver}','${route}')">💬 Chat</button>`
              : '';
            const cancelBtn = canCancel
              ? `<button class="btn-danger" onclick="confirmCancelBooking('${b.bookingId}','${route}')">✕ Cancel</button>`
              : '';
            tbody.innerHTML += `
        <tr>
          <td>
            <div class="rider-info">
              <div class="rider-avatar" style="background:linear-gradient(135deg,var(--green),#27AE60)">${initial}</div>
              <div>
                <div class="rider-name">${driver}</div>
                <div class="rider-id">Driver</div>
              </div>
            </div>
          </td>
          <td>
            <div class="route-cell">
              <div class="route-main">${b.pickup || '—'} → ${b.destination || '—'}</div>
              <div class="route-date">${fmtDate(b.date)}</div>
            </div>
          </td>
          <td>
            <div class="fare-cell">
              <div class="fare-main">₹${b.fare || 0}</div>
              <div class="fare-seats">${seats} seat${seats > 1 ? 's' : ''}</div>
            </div>
          </td>
          <td>${statusBadge(b.status)}</td>
          <td style="display:flex;gap:6px;flex-wrap:wrap;align-items:center;">${contactBtn}${cancelBtn}</td>
        </tr>`;
          });

        } catch (err) {
          console.error("Booked rides error:", err);
          document.getElementById("bookedRidesTable").innerHTML =
            `<tr class="table-empty"><td colspan="4">Could not load bookings. Is the server running?</td></tr>`;
        }
      }

      // ================= REAL-TIME (Socket.IO) =================
      let chatSocket = null;
      let activeChatBookingId = null;
      let myUserId = null; // populated by /api/v4/user/me — set BEFORE connectSocket()

      function connectSocket() {
        const t = ( localStorage.getItem("token") || sessionStorage.getItem("token") );
        if (!t) return;

        // Use a relative origin so the app works on any host/port
        chatSocket = io(window.location.origin);

        chatSocket.on("connect", () => {
          chatSocket.emit("join", t);
          const dot = document.getElementById("live-dot");
          if (dot) { dot.style.background = "#2ECC71"; dot.title = "Live"; }
        });

        chatSocket.on("disconnect", () => {
          const dot = document.getElementById("live-dot");
          if (dot) { dot.style.background = "#E74C3C"; dot.title = "Disconnected"; }
        });

        // New booking request → refresh posted rides table
        chatSocket.on("new-notification", () => { fetchPostedRides(); });

        // Booking accepted/rejected → refresh both tables
        chatSocket.on("booking-updated", () => { fetchPostedRides(); fetchBookedRides(); });

        // ── Chat events ──
        chatSocket.on("chat-message", (msg) => {
          if (msg.bookingId !== activeChatBookingId) return;
          appendChatMessage(msg);
        });

        chatSocket.on("chat-error", (errMsg) => { lockChat(errMsg); });
      }

      // ================= CHAT HELPERS =================
      function openChat(bookingId, otherName, route) {
        activeChatBookingId = bookingId;
        document.getElementById("chatTitle").textContent = `Chat with ${otherName}`;
        document.getElementById("chatSub").textContent = route;
        document.getElementById("chatBody").innerHTML = '<div class="chat-empty">💬 <span>Loading…</span></div>';
        document.getElementById("chatLocked").style.display = "none";
        document.getElementById("chatFooter").style.display = "flex";
        document.getElementById("chatInput").disabled = false;
        document.getElementById("chatSendBtn").disabled = false;
        document.getElementById("chatOverlay").classList.add("open");

        const t = ( localStorage.getItem("token") || sessionStorage.getItem("token") );
        if (chatSocket) chatSocket.emit("join-chat", { bookingId, token: t });
        loadChatHistory(bookingId);
      }

      function closeChat() {
        document.getElementById("chatOverlay").classList.remove("open");
        activeChatBookingId = null;
      }

      async function loadChatHistory(bookingId) {
        try {
          const res = await fetch(`/api/v4/chat/${bookingId}`, {
            headers: { Authorization: `Bearer ${( localStorage.getItem("token") || sessionStorage.getItem("token") )}` }
          });
          const data = await res.json();
          const body = document.getElementById("chatBody");
          body.innerHTML = "";

          // Render history first (so messages are visible even for ended rides)
          if (!data.messages || !data.messages.length) {
            body.innerHTML = '<div class="chat-empty">💬 <span>No messages yet — say hello!</span></div>';
          } else {
            data.messages.forEach(msg => appendChatMessage(msg, true));
            scrollChatToBottom();
          }

          // Lock the footer AFTER rendering — chat inactive means ride ended
          if (!data.isChatActive) lockChat("Chat is closed — the ride has ended.");
        } catch (e) { console.error("loadChatHistory:", e); }
      }

      function appendChatMessage(msg, suppressScroll = false) {
        const body = document.getElementById("chatBody");
        const isEmpty = body.querySelector(".chat-empty");
        if (isEmpty) isEmpty.remove();

        const isMe = msg.senderId?._id === myUserId || msg.senderId === myUserId;
        const name = msg.senderId?.name || "";
        const time = msg.createdAt
          ? new Date(msg.createdAt).toLocaleTimeString("en-IN", { hour: "2-digit", minute: "2-digit" })
          : "";

        const el = document.createElement("div");
        el.className = `chat-msg ${isMe ? "mine" : "theirs"}`;
        el.innerHTML = `
    <div>${escapeHtml(msg.text)}</div>
    <div class="chat-msg-meta">${isMe ? "You" : escapeHtml(name)} · ${time}</div>
  `;
        body.appendChild(el);
        if (!suppressScroll) scrollChatToBottom();
      }

      function lockChat(reason) {
        const locked = document.getElementById("chatLocked");
        const footer = document.getElementById("chatFooter");
        locked.textContent = `🔒 ${reason || "Chat is closed."}`;
        locked.style.display = "block";
        footer.style.display = "none";
      }

      function scrollChatToBottom() {
        const body = document.getElementById("chatBody");
        body.scrollTop = body.scrollHeight;
      }

      function sendChatMessage() {
        const input = document.getElementById("chatInput");
        const text = input.value.trim();
        // Guard: socket must exist AND be connected
        if (!text || !activeChatBookingId || !chatSocket || !chatSocket.connected) {
          if (chatSocket && !chatSocket.connected) {
            console.warn("Socket disconnected — message not sent.");
          }
          return;
        }
        chatSocket.emit("chat-message", {
          bookingId: activeChatBookingId,
          token: ( localStorage.getItem("token") || sessionStorage.getItem("token") ),
          text
        });
        input.value = "";
        input.focus();
      }

      function escapeHtml(str) {
        return String(str)
          .replace(/&/g, "&amp;").replace(/</g, "&lt;")
          .replace(/>/g, "&gt;").replace(/"/g, "&quot;");
      }

      // ================= CONFIRM + CANCEL HELPERS =================
      let _pendingAction = null;

      function openConfirm({ icon, title, body, actionLabel, onConfirm }) {
        document.getElementById('confirmIcon').textContent = icon || '⚠️';
        document.getElementById('confirmTitle').textContent = title || 'Are you sure?';
        document.getElementById('confirmBody').textContent = body || 'This action cannot be undone.';
        const btn = document.getElementById('confirmActionBtn');
        btn.textContent = actionLabel || 'Confirm';
        _pendingAction = onConfirm;
        btn.onclick = async () => {
          closeConfirm();
          await _pendingAction();
        };
        document.getElementById('confirmOverlay').classList.add('open');
      }

      function closeConfirm() {
        document.getElementById('confirmOverlay').classList.remove('open');
        _pendingAction = null;
      }

      function showToast(message, type = 'success') {
        const t = document.getElementById('toast');
        t.textContent = message;
        t.className = `toast ${type}`;
        t.classList.add('show');
        setTimeout(() => { t.classList.remove('show'); }, 3200);
      }

      function confirmCancelRide(rideId, route) {
        openConfirm({
          icon: '🚗',
          title: 'Cancel this ride?',
          body: `"${route}" will be cancelled and all passengers will be notified.`,
          actionLabel: 'Yes, cancel ride',
          onConfirm: async () => {
            try {
              const res = await fetch(`/api/v4/rides/cancel/${rideId}`, {
                method: 'PATCH',
                headers: { Authorization: `Bearer ${token}` }
              });
              const data = await res.json();
              if (!res.ok) throw new Error(data.message || 'Failed to cancel ride');
              showToast('Ride cancelled successfully 🚗', 'success');
              fetchPostedRides();
            } catch (err) {
              showToast(err.message, 'error');
            }
          }
        });
      }

      function confirmCancelBooking(bookingId, route) {
        openConfirm({
          icon: '🎫',
          title: 'Cancel your booking?',
          body: `Your booking for "${route}" will be cancelled. If already accepted, your seat will be freed.`,
          actionLabel: 'Yes, cancel booking',
          onConfirm: async () => {
            try {
              const res = await fetch(`/api/v4/bookings/cancel/${bookingId}`, {
                method: 'PATCH',
                headers: { Authorization: `Bearer ${token}` }
              });
              const data = await res.json();
              if (!res.ok) throw new Error(data.error || 'Failed to cancel booking');
              showToast('Booking cancelled successfully 🎫', 'success');
              fetchBookedRides();
            } catch (err) {
              showToast(err.message, 'error');
            }
          }
        });
      }

      // ================= INIT =================
      document.addEventListener("DOMContentLoaded", async () => {
        fetchPostedRides();
        fetchBookedRides();

        // Resolve myUserId BEFORE starting socket so chat bubbles are
        // correctly labelled "mine" vs "theirs" from the very first message.
        const t = ( localStorage.getItem("token") || sessionStorage.getItem("token") );
        if (t && !myUserId) {
          try {
            const r = await fetch("/api/v4/user/me", {
              headers: { Authorization: `Bearer ${t}` }
            });
            const d = await r.json();
            if (d.success && d.user?._id) myUserId = d.user._id;
          } catch (_) { /* non-critical */ }
        }

        connectSocket();

        // Enter key to send
        const chatInput = document.getElementById("chatInput");
        if (chatInput) {
          chatInput.addEventListener("keydown", (e) => {
            if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendChatMessage(); }
          });
        }

        // Click overlay to close chat
        document.getElementById("chatOverlay").addEventListener("click", (e) => {
          if (e.target === document.getElementById("chatOverlay")) closeChat();
        });

        // Click overlay to close confirm modal
        document.getElementById("confirmOverlay").addEventListener("click", (e) => {
          if (e.target === document.getElementById("confirmOverlay")) closeConfirm();
        });
      });
    </script>
  </main>

  <script>
    (async () => {
      const token = ( localStorage.getItem("token") || sessionStorage.getItem("token") );
      if (!token) return;

      // ── Time-based greeting ─────────────────────────────────────
      const hour = new Date().getHours();
      const greetWord = hour < 12 ? "Good morning 🌅"
        : hour < 17 ? "Good afternoon ☀️"
          : "Good evening 🌙";
      const greetTimeEl = document.getElementById("greet-time");
      if (greetTimeEl) greetTimeEl.textContent = greetWord;

      // ── User name ───────────────────────────────────────────────
      try {
        const res = await fetch("/api/v4/user/me", {
          headers: { Authorization: `Bearer ${token}` }
        });
        const data = await res.json();
        if (data.success) {
          const u = data.user;
          const initials = (u.name || "U").split(" ").map(n => n[0]).join("").toUpperCase().slice(0, 2);
          const firstName = u.name ? u.name.split(" ")[0] : "there";
          document.getElementById("sb-avatar").textContent = initials;
          document.getElementById("sb-name").textContent = u.name || "User";
          document.getElementById("sb-role").textContent = u.role || "Passenger";
          document.getElementById("top-avatar").textContent = initials;
          document.getElementById("top-name").textContent = u.name || "User";
          document.getElementById("greet-name").textContent = `Welcome back, ${firstName}! 👋`;
          // expose userId for chat bubble identification
          myUserId = u._id;
        }
      } catch (e) { /* silent */ }

      // ── Ride counts for banner stats ────────────────────────────
      try {
        const [postedRes, bookedRes] = await Promise.all([
          fetch("/api/v4/bookings/my-rides", {
            headers: { Authorization: `Bearer ${token}` }
          }),
          fetch("/api/v4/bookings/my-bookings", {
            headers: { Authorization: `Bearer ${token}` }
          })
        ]);

        const posted = await postedRes.json();
        const booked = await bookedRes.json();

        const postedCount = Array.isArray(posted) ? posted.length : 0;
        const bookedCount = Array.isArray(booked) ? booked.length : 0;

        document.getElementById("stat-posted").textContent = postedCount;
        document.getElementById("stat-booked").textContent = bookedCount;

        const sub = document.getElementById("greet-sub");
        if (sub) {
          if (bookedCount > 0) {
            sub.innerHTML = `You have <strong>${bookedCount}</strong> ride${bookedCount > 1 ? 's' : ''} booked and <strong>${postedCount}</strong> posted.`;
          } else if (postedCount > 0) {
            sub.innerHTML = `You've posted <strong>${postedCount}</strong> ride${postedCount > 1 ? 's' : ''}. Waiting for passengers!`;
          } else {
            sub.textContent = "Post or book a ride to get started 🚗";
          }
        }
      } catch (e) { /* silent */ }
    })();
  </script>

</body>

</html>