<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Post a Ride – Mitra Ride</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Rozha+One&family=Noto+Sans+Devanagari:wght@400;700&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <style>
    :root {
      --bg: #FAFAF8;
      --bg2: #F5F3EE;
      --white: #FFFFFF;
      --sb-bg: rgba(255, 255, 255, 0.85);
      --card: #FFFFFF;
      --card2: #F9F8F5;
      --border: #E8E5DF;
      --border2: rgba(232, 229, 223, 0.7);
      --orange: #FF8C00;
      --orange-light: #FFF3E0;
      --orange-mid: #FFDFA0;
      --orange-deep: #FF6B00;
      --emerald: #2ECC71;
      --emerald-light: #E8FAF1;
      --emerald-dark: #1DAF5F;
      --amber: #E8860A;
      --red: #EF4444;
      --blue: #0EA5E9;
      --navy: #1A1A2E;
      --charcoal: #2C2C3E;
      --t2: #6B7280;
      --t3: #9CA3AF;
      --shadow-sm: 0 2px 8px rgba(26, 26, 46, 0.05), 0 1px 3px rgba(26, 26, 46, 0.04);
      --shadow-card: 0 4px 20px rgba(26, 26, 46, 0.06), 0 1px 4px rgba(26, 26, 46, 0.04);
      --shadow-float: 0 8px 30px rgba(0, 0, 0, 0.04), 0 2px 8px rgba(0, 0, 0, 0.03);
      --shadow-orange: 0 6px 20px rgba(255, 140, 0, 0.28);
      --shadow-orange-hover: 0 12px 32px rgba(255, 140, 0, 0.38);
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      color: var(--navy);
      display: flex;
      min-height: 100vh;
      font-size: 14px;
      background-image:
        radial-gradient(ellipse at 5% 0%, rgba(255, 140, 0, 0.04) 0%, transparent 55%),
        radial-gradient(ellipse at 95% 100%, rgba(46, 204, 113, 0.04) 0%, transparent 55%);
    }

    /* ── SIDEBAR ── */
    #sidebar {
      width: 240px;
      min-width: 240px;
      flex-shrink: 0;
      background: rgba(255, 255, 255, 0.82);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      padding: 28px 0;
      height: 100vh;
      overflow-y: auto;
      box-shadow: 2px 0 24px rgba(0, 0, 0, 0.04);
      position: fixed;
      top: 0;
      left: 0;
      z-index: 100;
    }

    .logo-box {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0 24px 32px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 20px;
      color: var(--navy);
      letter-spacing: -0.3px;
    }

    .logo-box .hindi {
      font-family: 'Rozha One', 'Noto Sans Devanagari', serif;
      font-weight: 900;
      color: var(--orange);
    }

    .logo-icon {
      width: 36px;
      height: 36px;
      background: linear-gradient(135deg, var(--orange), #FF6B00);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
      box-shadow: 0 4px 12px rgba(255, 140, 0, 0.3);
    }

    .post-btn {
      margin: 0 12px 24px;
      width: calc(100% - 24px);
      padding: 12px 16px;
      background: linear-gradient(135deg, var(--orange), #FF6B00);
      border: none;
      border-radius: 14px;
      color: #fff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      box-shadow: 0 4px 20px rgba(255, 140, 0, 0.35);
      letter-spacing: 0.3px;
      transition: opacity 0.2s, transform 0.15s;
      text-decoration: none;
    }

    .post-btn:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }

    .post-btn:active {
      transform: translateY(0);
    }

    .section-label {
      font-size: 10px;
      font-weight: 700;
      color: var(--muted2);
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 0 12px 10px;
      margin: 0 12px;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .nav-section {
      padding: 0 12px;
      margin-bottom: 24px;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.2s;
      font-size: 14px;
      color: var(--muted);
      font-weight: 500;
      margin-bottom: 2px;
      text-decoration: none;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .nav-item:hover {
      background: #F5F3EE;
      color: var(--navy);
    }

    .nav-item.active {
      background: linear-gradient(90deg, rgba(255, 140, 0, 0.12), rgba(255, 140, 0, 0.05));
      color: var(--orange);
      border: 1px solid rgba(255, 140, 0, 0.2);
      font-weight: 600;
    }

    .nav-item .icon {
      font-size: 16px;
      width: 20px;
      text-align: center;
    }

    .user-row {
      margin-top: auto;
      padding: 0 12px;
    }

    .user-card {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      background: #F5F3EE;
      border-radius: 14px;
      border: 1px solid var(--border);
      box-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
      cursor: pointer;
    }

    .avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 700;
      color: white;
      flex-shrink: 0;
      background: linear-gradient(135deg, var(--orange), #FF6B00);
    }

    /* ── MAIN ── */
    .main {
      margin-left: 240px;
      flex: 1;
      display: flex;
      flex-direction: column
    }


    .sb-logo {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 18px 16px 20px;
      border-bottom: 1px solid var(--border)
    }

    .sb-logo-icon {
      width: 34px;
      height: 34px;
      border-radius: 9px;
      background: linear-gradient(135deg, var(--orange), #FFA040);
      display: grid;
      place-items: center;
      font-size: 17px;
      flex-shrink: 0;
      box-shadow: 0 4px 12px rgba(255, 140, 0, 0.3)
    }

    .sb-logo-text {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 14px;
      line-height: 1.2;
      color: var(--navy)
    }

    .sb-logo-text em {
      font-style: normal;
      font-family: 'Rozha One', 'Noto Sans Devanagari', serif;
      color: var(--orange);
      font-weight: 400;
      font-size: 15px
    }

    .sb-post {
      margin: 14px 12px;
      padding: 11px;
      background: linear-gradient(135deg, var(--orange), var(--orange-deep));
      border: none;
      border-radius: 12px;
      color: #fff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700;
      font-size: 13px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      box-shadow: var(--shadow-orange);
      transition: all .2s
    }

    .sb-post:hover {
      transform: translateY(-1px);
      box-shadow: var(--shadow-orange-hover)
    }

    .sb-sec {
      padding: 14px 10px 4px
    }

    .sb-lbl {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .12em;
      color: var(--t3);
      text-transform: uppercase;
      padding: 0 8px 8px;
      font-family: 'Plus Jakarta Sans', sans-serif
    }

    .sb-item {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 8px 10px;
      border-radius: 10px;
      color: var(--t2);
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: all .15s;
      text-decoration: none
    }

    .sb-item:hover {
      background: var(--orange-light);
      color: var(--orange)
    }

    .sb-item.active {
      background: var(--orange-light);
      color: var(--orange);
      font-weight: 700;
      box-shadow: inset 3px 0 0 var(--orange)
    }

    .badge {
      margin-left: auto;
      background: var(--orange);
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: 99px;
      box-shadow: 0 2px 6px rgba(255, 140, 0, 0.3)
    }

    .sb-foot {
      margin-top: auto;
      padding: 12px 10px;
      border-top: 1px solid var(--border);
      background: rgba(250, 250, 248, 0.6)
    }

    .user-chip {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 7px 9px;
      border-radius: 10px;
      cursor: pointer;
      transition: background .15s
    }

    .user-chip:hover {
      background: var(--bg2)
    }

    .av {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--orange), var(--orange-deep));
      display: grid;
      place-items: center;
      font-size: 10px;
      font-weight: 700;
      flex-shrink: 0;
      color: #fff;
      box-shadow: 0 2px 8px rgba(255, 140, 0, 0.3)
    }

    .u-name {
      font-size: 12.5px;
      font-weight: 700;
      color: var(--navy)
    }

    .u-role {
      font-size: 11px;
      color: var(--t3)
    }

    .more {
      margin-left: auto;
      color: var(--t3);
      font-size: 16px
    }


    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 28px;
      border-bottom: 1px solid var(--border);
      background: rgba(250, 250, 248, 0.9);
      position: sticky;
      top: 0;
      z-index: 40;
      backdrop-filter: blur(12px);
      box-shadow: 0 1px 0 var(--border);
    }

    .breadcrumb {
      font-size: 12px;
      color: var(--t2)
    }

    .breadcrumb a {
      color: var(--t2);
      text-decoration: none
    }

    .breadcrumb a:hover {
      color: var(--orange)
    }

    .breadcrumb span {
      color: var(--navy);
      font-weight: 600
    }

    .top-right {
      display: flex;
      align-items: center;
      gap: 12px
    }

    .search-box {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 8px 13px;
      box-shadow: var(--shadow-sm);
      transition: border-color .2s
    }

    .search-box:focus-within {
      border-color: var(--orange)
    }

    .search-box input {
      background: none;
      border: none;
      outline: none;
      color: var(--navy);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px;
      width: 160px
    }

    .search-box input::placeholder {
      color: var(--t3)
    }

    .icon-btn {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      background: var(--white);
      border: 1px solid var(--border);
      display: grid;
      place-items: center;
      cursor: pointer;
      font-size: 15px;
      color: var(--t2);
      transition: all .15s;
      position: relative;
      box-shadow: var(--shadow-sm)
    }

    .icon-btn:hover {
      border-color: var(--orange);
      color: var(--orange)
    }

    .ndot {
      position: absolute;
      top: 5px;
      right: 5px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--amber);
      border: 2px solid var(--bg)
    }

    .avbtn {
      display: flex;
      align-items: center;
      gap: 7px;
      cursor: pointer
    }

    .avbtn .av {
      width: 32px;
      height: 32px;
      font-size: 11px
    }

    .avbtn span {
      font-size: 13px;
      font-weight: 600;
      color: var(--navy)
    }

    .page-header {
      padding: 26px 28px 0;
      display: flex;
      align-items: flex-start;
      justify-content: space-between
    }

    .page-title {
      font-family: 'Rozha One', serif;
      font-weight: 400;
      font-size: 26px;
      color: var(--navy);
      letter-spacing: -0.3px
    }

    .page-sub {
      font-size: 13px;
      color: var(--t2);
      margin-top: 5px;
      font-weight: 400
    }

    .back-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 10px;
      color: var(--t2);
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: all .15s;
      text-decoration: none;
      white-space: nowrap;
      box-shadow: var(--shadow-sm)
    }

    .back-btn:hover {
      border-color: var(--orange);
      color: var(--orange)
    }

    /* ── CONTENT GRID ── */
    .content {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 20px;
      padding: 22px 28px 40px;
      align-items: start;
    }

    /* ── MAP SECTION — full-width inside form col ── */
    .map-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 24px;
      margin-bottom: 16px;
      box-shadow: var(--shadow-card);
      overflow: hidden;
    }

    .map-card-header {
      padding: 18px 24px 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border2);
    }

    .map-card-left {
      display: flex;
      align-items: center;
      gap: 9px
    }

    .card-icon {
      width: 32px;
      height: 32px;
      border-radius: 10px;
      display: grid;
      place-items: center;
      font-size: 14px;
      flex-shrink: 0
    }

    .card-icon.g {
      background: var(--emerald-light)
    }

    .card-icon.p {
      background: var(--orange-light)
    }

    .card-icon.a {
      background: #FFF8EC;
      border: 1px solid rgba(232, 134, 10, .15)
    }

    .card-icon.b {
      background: #EFF9FF;
      border: 1px solid rgba(14, 165, 233, .15)
    }

    .card-icon.map {
      background: linear-gradient(135deg, #EFF9FF, #E8FAF1)
    }

    .card-title {
      font-family: 'Rozha One', serif;
      font-weight: 400;
      font-size: 16px;
      color: var(--navy);
      letter-spacing: -0.2px
    }

    .card-sub {
      font-size: 12px;
      color: var(--t2)
    }

    /* Map mode toggle */
    .map-mode-toggle {
      display: flex;
      gap: 5px
    }

    .mode-btn {
      padding: 5px 11px;
      border-radius: 8px;
      font-size: 11px;
      font-weight: 700;
      border: 1.5px solid var(--border);
      background: var(--bg2);
      color: var(--t2);
      cursor: pointer;
      transition: all .18s;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .mode-btn.active {
      background: var(--orange);
      color: white;
      border-color: var(--orange);
      box-shadow: 0 3px 10px rgba(255, 140, 0, .25)
    }

    /* Map instruction banner */
    .map-instruction {
      background: linear-gradient(90deg, var(--orange-light), rgba(232, 250, 241, .6));
      border-bottom: 1px solid var(--border2);
      padding: 9px 18px;
      font-size: 12px;
      color: var(--charcoal);
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .instr-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0
    }

    .instr-dot.orange {
      background: var(--orange)
    }

    .instr-dot.green {
      background: var(--emerald)
    }

    /* Map itself */
    #post-map {
      width: 100%;
      height: 320px
    }

    /* Map overlays */
    .map-overlay {
      position: absolute;
      z-index: 500;
      background: rgba(255, 255, 255, 0.95);
      border-radius: 12px;
      box-shadow: 0 6px 24px rgba(26, 26, 46, 0.12);
      border: 1px solid var(--border);
      backdrop-filter: blur(8px);
    }

    /* Route info bar under map */
    #route-info-bar {
      padding: 12px 18px;
      border-top: 1px solid var(--border2);
      background: var(--bg2);
      display: none;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .ri-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--t2)
    }

    .ri-val {
      font-weight: 800;
      color: var(--navy);
      font-size: 13px
    }

    .ri-val.orange {
      color: var(--orange)
    }

    .ri-val.green {
      color: var(--emerald-dark)
    }

    .ri-sep {
      width: 1px;
      height: 20px;
      background: var(--border);
      flex-shrink: 0
    }

    .clear-route-btn {
      margin-left: auto;
      padding: 5px 12px;
      border-radius: 8px;
      background: #FFF5F5;
      border: 1.5px solid rgba(239, 68, 68, .2);
      color: #EF4444;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Plus Jakarta Sans', sans-serif;
      transition: all .15s;
    }

    .clear-route-btn:hover {
      background: #EF4444;
      color: white
    }

    /* Map search inputs row */
    .map-search-row {
      padding: 12px 18px;
      display: flex;
      gap: 8px;
      align-items: center;
      border-top: 1px solid var(--border2);
      background: var(--white);
    }

    .map-inp-wrap {
      flex: 1;
      position: relative
    }

    .map-inp-icon {
      position: absolute;
      left: 10px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 12px;
      pointer-events: none
    }

    .map-search-input {
      width: 100%;
      padding: 9px 9px 9px 28px;
      background: var(--bg2);
      border: 1.5px solid var(--border);
      border-radius: 10px;
      font-size: 12.5px;
      font-weight: 500;
      color: var(--navy);
      font-family: 'Plus Jakarta Sans', sans-serif;
      outline: none;
      transition: all .2s;
    }

    .map-search-input:focus {
      border-color: var(--orange);
      background: var(--white);
      box-shadow: 0 0 0 3px rgba(255, 140, 0, .1)
    }

    .map-search-input::placeholder {
      color: var(--t3);
      font-weight: 400
    }

    .map-geo-btn {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: var(--orange-light);
      border: 1.5px solid var(--orange-mid);
      color: var(--orange);
      font-size: 14px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all .18s;
      flex-shrink: 0;
    }

    .map-geo-btn:hover {
      background: var(--orange);
      color: white;
      border-color: var(--orange)
    }

    /* Geocode suggestion dropdown */
    .geo-dropdown {
      position: absolute;
      top: calc(100% + 4px);
      left: 0;
      right: 0;
      z-index: 600;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 10px;
      box-shadow: 0 8px 24px rgba(26, 26, 46, .12);
      overflow: hidden;
      display: none;
    }

    .geo-option {
      padding: 9px 12px;
      font-size: 12px;
      color: var(--navy);
      cursor: pointer;
      transition: background .12s;
      font-weight: 500;
      border-bottom: 1px solid var(--border2);
    }

    .geo-option:last-child {
      border-bottom: none
    }

    .geo-option:hover {
      background: var(--orange-light);
      color: var(--orange)
    }

    .geo-sub {
      font-size: 10.5px;
      color: var(--t3);
      font-weight: 400
    }

    /* Map controls */
    .map-controls-abs {
      position: absolute;
      bottom: 14px;
      right: 14px;
      z-index: 500;
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .map-ctrl {
      width: 32px;
      height: 32px;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 9px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 13px;
      box-shadow: var(--shadow-card);
      transition: all .18s
    }

    .map-ctrl:hover {
      background: var(--orange-light);
      border-color: var(--orange)
    }

    /* Distance overlay on map */
    #map-dist-overlay {
      top: 12px;
      left: 12px;
      padding: 10px 14px;
      min-width: 160px;
      display: none;
    }

    .mdo-title {
      font-size: 9px;
      font-weight: 700;
      color: var(--t3);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 7px
    }

    .mdo-row {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      margin-bottom: 4px
    }

    .mdo-lbl {
      color: var(--t2)
    }

    .mdo-val {
      font-weight: 800;
      color: var(--navy)
    }

    .mdo-val.o {
      color: var(--orange)
    }

    /* ── CARDS ── */
    .card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 22px 24px;
      margin-bottom: 16px;
      box-shadow: var(--shadow-card);
      transition: box-shadow .2s;
    }

    .card:last-child {
      margin-bottom: 0
    }

    .card:hover {
      box-shadow: 0 8px 28px rgba(26, 26, 46, 0.08)
    }

    .card-head {
      display: flex;
      align-items: center;
      gap: 9px;
      margin-bottom: 4px
    }

    .card-sub-text {
      font-size: 12.5px;
      color: var(--t2);
      margin-bottom: 18px;
      margin-left: 41px
    }

    .divider {
      border: none;
      border-top: 1.5px dashed var(--border);
      margin: 16px 0
    }

    /* ── FORM FIELDS ── */
    .field {
      margin-bottom: 14px
    }

    .field:last-child {
      margin-bottom: 0
    }

    label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--t2);
      margin-bottom: 6px
    }

    .fi {
      position: relative;
      display: flex;
      align-items: center
    }

    .fi .ico {
      position: absolute;
      left: 11px;
      font-size: 13px;
      pointer-events: none;
      z-index: 1
    }

    .fi input,
    .fi select,
    .fi textarea {
      width: 100%;
      background: var(--bg2);
      border: 1.5px solid var(--border);
      border-radius: 12px;
      padding: 10px 11px 10px 34px;
      color: var(--navy);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13.5px;
      font-weight: 500;
      outline: none;
      transition: border-color .2s, box-shadow .2s, background .2s;
      -webkit-appearance: none;
      appearance: none;
    }

    .fi input:focus,
    .fi select:focus,
    .fi textarea:focus {
      border-color: var(--orange);
      background: var(--white);
      box-shadow: 0 0 0 3px rgba(255, 140, 0, 0.10);
    }

    .fi input::placeholder,
    .fi textarea::placeholder {
      color: var(--t3);
      font-weight: 400
    }

    .fi select option {
      background: var(--white);
      color: var(--navy)
    }

    .fi textarea {
      padding-left: 34px;
      resize: vertical;
      min-height: 70px
    }

    .no-ico input,
    .no-ico select,
    .no-ico textarea {
      padding-left: 12px
    }

    .g2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 13px
    }

    .g3 {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 13px
    }

    .hint {
      font-size: 11.5px;
      color: var(--t3);
      margin-top: 5px
    }

    /* seats picker */
    .seat-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap
    }

    .s-btn {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      border: 1.5px solid var(--border);
      background: var(--bg2);
      color: var(--t2);
      font-family: 'Rozha One', serif;
      font-size: 16px;
      cursor: pointer;
      display: grid;
      place-items: center;
      transition: all .18s;
    }

    .s-btn:hover {
      border-color: var(--orange);
      color: var(--orange);
      background: var(--orange-light)
    }

    .s-btn.on {
      background: linear-gradient(135deg, var(--orange), var(--orange-deep));
      border-color: var(--orange);
      color: #fff;
      box-shadow: 0 4px 14px rgba(255, 140, 0, 0.3);
      transform: translateY(-1px)
    }

    /* amenity chips */
    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 7px
    }

    .chip {
      padding: 6px 13px;
      border-radius: 99px;
      border: 1.5px solid var(--border);
      background: var(--bg2);
      font-size: 12px;
      font-weight: 600;
      color: var(--t2);
      cursor: pointer;
      user-select: none;
      transition: all .15s
    }

    .chip:hover {
      border-color: var(--emerald);
      color: var(--emerald-dark);
      background: var(--emerald-light)
    }

    .chip.on {
      background: var(--emerald-light);
      border-color: rgba(46, 204, 113, 0.4);
      color: var(--emerald-dark)
    }

    /* price slider */
    .price-display {
      font-family: 'Rozha One', serif;
      font-weight: 400;
      font-size: 36px;
      color: var(--amber);
      margin-bottom: 10px;
      display: flex;
      align-items: baseline;
      gap: 3px
    }

    .price-display span {
      font-size: 20px
    }

    input[type=range] {
      -webkit-appearance: none;
      appearance: none;
      width: 100%;
      height: 5px;
      border-radius: 99px;
      border: none;
      outline: none;
      cursor: pointer;
      padding: 0
    }

    input[type=range]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      cursor: pointer
    }

    input[type=range].amber-r {
      background: linear-gradient(to right, var(--orange) 20%, var(--border) 20%)
    }

    input[type=range].amber-r::-webkit-slider-thumb {
      background: var(--orange);
      box-shadow: 0 0 0 3px rgba(255, 140, 0, 0.2), 0 2px 6px rgba(255, 140, 0, 0.3)
    }

    /* ── RIGHT COL ── */
    .right-col {
      display: flex;
      flex-direction: column;
      gap: 16px;
      position: sticky;
      top: 70px
    }

    .sum-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 9px 0;
      border-bottom: 1.5px dashed var(--border);
      font-size: 13px
    }

    .sum-row:last-child {
      border-bottom: none
    }

    .sum-lbl {
      color: var(--t2);
      font-weight: 500
    }

    .sum-val {
      font-weight: 700;
      color: var(--navy)
    }

    .sum-val.g {
      color: var(--emerald-dark)
    }

    .sum-val.a {
      color: var(--amber)
    }

    .sum-val.p {
      color: var(--orange)
    }

    .rvis {
      padding: 10px 0 14px
    }

    .rstop {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 3px 0;
      position: relative
    }

    .rdot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0
    }

    .rdot.f {
      background: var(--orange);
      box-shadow: 0 0 0 3px rgba(255, 140, 0, 0.2)
    }

    .rdot.t {
      background: var(--emerald);
      box-shadow: 0 0 0 3px rgba(46, 204, 113, 0.2)
    }

    .rline {
      position: absolute;
      left: 4.5px;
      top: 13px;
      bottom: -4px;
      width: 1px;
      background: var(--border)
    }

    .rgap {
      height: 14px
    }

    .rname {
      font-size: 13px;
      font-weight: 700;
      color: var(--navy)
    }

    .rsub {
      font-size: 11px;
      color: var(--t3)
    }

    .vstrip {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      background: var(--emerald-light);
      border: 1px solid rgba(46, 204, 113, 0.25);
      border-radius: 12px;
      padding: 11px 13px;
      margin-top: 4px
    }

    .vstrip p {
      font-size: 12px;
      color: var(--t2);
      line-height: 1.55
    }

    .vstrip p strong {
      color: var(--emerald-dark)
    }

    .btn-post {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, var(--orange), var(--orange-deep));
      border: none;
      border-radius: 14px;
      color: #fff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 15px;
      font-weight: 800;
      cursor: pointer;
      transition: all .22s;
      box-shadow: var(--shadow-orange);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      margin-top: 14px;
      letter-spacing: 0.2px
    }

    .btn-post:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-orange-hover)
    }

    .btn-cancel {
      width: 100%;
      padding: 11px;
      background: var(--bg2);
      border: 1.5px solid var(--border);
      border-radius: 12px;
      color: var(--t2);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13.5px;
      font-weight: 500;
      cursor: pointer;
      transition: all .15s;
      margin-top: 8px
    }

    .btn-cancel:hover {
      border-color: var(--red);
      color: var(--red);
      background: #FFF5F5
    }

    .tip-item {
      display: flex;
      gap: 8px;
      font-size: 12.5px;
      color: var(--t2);
      line-height: 1.55;
      margin-bottom: 9px;
      font-weight: 400
    }

    .tip-item:last-child {
      margin-bottom: 0
    }

    .sec-lbl {
      font-size: 10.5px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: var(--t3);
      margin-bottom: 10px
    }

    .ticket-top-bar {
      height: 5px;
      margin: -22px -24px 20px;
      background: linear-gradient(90deg, var(--orange), #FFB347, var(--emerald));
      border-radius: 24px 24px 0 0
    }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 26px;
      right: 26px;
      background: var(--white);
      border: 1px solid rgba(46, 204, 113, 0.35);
      border-radius: 16px;
      padding: 14px 18px;
      display: flex;
      align-items: center;
      gap: 10px;
      transform: translateY(70px);
      opacity: 0;
      transition: all .4s cubic-bezier(.34, 1.56, .64, 1);
      z-index: 300;
      pointer-events: none;
      max-width: 300px;
      box-shadow: 0 12px 40px rgba(46, 204, 113, 0.12), 0 4px 16px rgba(0, 0, 0, 0.06)
    }

    .toast.show {
      transform: translateY(0);
      opacity: 1
    }

    .toast-t {
      font-weight: 800;
      font-size: 13px;
      color: var(--emerald-dark)
    }

    .toast-m {
      font-size: 12px;
      color: var(--t2);
      margin-top: 2px
    }

    ::-webkit-scrollbar {
      width: 5px
    }

    ::-webkit-scrollbar-thumb {
      background: var(--orange-mid);
      border-radius: 99px
    }

    ::-webkit-scrollbar-track {
      background: var(--bg2)
    }

    /* Leaflet popup override */
    .leaflet-popup-content-wrapper {
      border-radius: 12px !important;
      box-shadow: 0 8px 24px rgba(26, 26, 46, .12) !important;
      font-family: 'Plus Jakarta Sans', sans-serif !important
    }

    .leaflet-popup-content {
      font-size: 12px !important;
      font-family: 'Plus Jakarta Sans', sans-serif !important
    }
  </style>
</head>

<body>

  <!-- SIDEBAR -->
  <div id="sidebar">
    <div class="logo-box">
      <div class="logo-icon">🚗</div>
      Ride <span class="hindi">मित्र</span>
    </div>

    <a href="/post-ride" class="post-btn">＋ &nbsp;Post a Ride</a>

    <div class="nav-section">
      <div class="section-label" style="margin:0 0 10px 0; padding: 0 2px;">Main</div>
      <a href="/dashboard" class="nav-item"><span class="icon">📊</span> Dashboard</a>
      <a href="/find-ride" class="nav-item"><span class="icon">🗺️</span> Find a Ride</a>
      <a href="/post-ride" class="nav-item active"><span class="icon">📅</span> My Rides</a>
      <a href="#" class="nav-item"><span class="icon">💰</span> Payments</a>
    </div>

    <div class="nav-section">
      <div class="section-label" style="margin:0 0 10px 0; padding: 0 2px;">Account</div>
      <a href="/notifications" class="nav-item"><span class="icon">🔔</span> Notifications</a>
      <a href="/account-settings" class="nav-item"><span class="icon">⚙️</span> Settings</a>
      <a href="/" class="nav-item"><span class="icon">🔐</span> Logout</a>
    </div>

    <div class="user-row">
      <div class="user-card">
        <div class="avatar" id="sb-avatar">--</div>
        <div>
          <div id="sb-name" style="font-size:13px; font-weight:700; color:var(--navy)">Loading...</div>
          <div id="sb-role" style="font-size:11px; color:var(--muted2); font-family:'Plus Jakarta Sans',sans-serif">
            Passenger</div>
        </div>
        <span style="margin-left:auto; color:var(--muted2); font-size:14px; cursor:pointer;">⋯</span>
      </div>
    </div>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- PAGE HEADER -->
    <div class="page-header">
      <div>
        <div class="page-title">Post a Ride 🚗</div>
        <div class="page-sub">Share your journey and split the fuel cost with verified passengers.</div>
      </div>
      <a class="back-btn" href="/dashboard">← Back to Dashboard</a>
    </div>

    <!-- CONTENT -->
    <div class="content">

      <!-- LEFT FORM COL -->
      <div>

        <!-- ═══════════════════════ MAP CARD ═══════════════════════ -->
        <div class="map-card">
          <div class="map-card-header">
            <div class="map-card-left">
              <div class="card-icon map">🗺️</div>
              <div>
                <div class="card-title">Set Route on Map</div>
                <div class="card-sub">Click map to place markers or search below</div>
              </div>
            </div>
            <div class="map-mode-toggle">
              <button class="mode-btn active" id="btn-click-mode" onclick="setMapMode('click')">📍 Click</button>
              <button class="mode-btn" id="btn-search-mode" onclick="setMapMode('search')">🔍 Search</button>
            </div>
          </div>

          <!-- Click-mode instruction banner -->
          <div class="map-instruction" id="map-instruction">
            <div class="instr-dot orange"></div>
            <span id="instr-text">Click on the map to set your <strong>Pickup point</strong></span>
          </div>

          <!-- The actual map -->
          <div style="position:relative">
            <div id="post-map"></div>

            <!-- Distance overlay on map -->
            <div class="map-overlay" id="map-dist-overlay">
              <div class="mdo-title">Route Info</div>
              <div class="mdo-row"><span class="mdo-lbl">Distance</span><span class="mdo-val o" id="mdo-km">—</span>
              </div>
              <div class="mdo-row"><span class="mdo-lbl">Est. Time</span><span class="mdo-val" id="mdo-time">—</span>
              </div>
              <div class="mdo-row"><span class="mdo-lbl">Suggested ₹</span><span class="mdo-val"
                  id="mdo-suggest">—</span></div>
            </div>

            <!-- Map controls -->
            <div class="map-controls-abs">
              <div class="map-ctrl" onclick="locateMe()" title="Use my location">📍</div>
              <div class="map-ctrl" onclick="fitRoute()" title="Fit route">⬚</div>
              <div class="map-ctrl" onclick="clearAllMarkers()" title="Clear markers">🗑</div>
            </div>
          </div>

          <!-- Search inputs row (visible in search mode) -->
          <div class="map-search-row" id="map-search-row" style="display:none">
            <div class="map-inp-wrap" style="position:relative">
              <span class="map-inp-icon">📍</span>
              <input class="map-search-input" id="map-from-inp" placeholder="Search pickup location…"
                oninput="suggestGeo(this,'from')" autocomplete="off" />
              <div class="geo-dropdown" id="dd-from"></div>
            </div>
            <div class="map-inp-wrap" style="position:relative">
              <span class="map-inp-icon">🏁</span>
              <input class="map-search-input" id="map-to-inp" placeholder="Search destination…"
                oninput="suggestGeo(this,'to')" autocomplete="off" />
              <div class="geo-dropdown" id="dd-to"></div>
            </div>
            <button class="map-geo-btn" onclick="locateMe()" title="Use GPS">🎯</button>
          </div>

          <!-- Route info bar -->
          <div id="route-info-bar">
            <div class="ri-item">📏 <span class="ri-val orange" id="ri-km">—</span>&nbsp;km</div>
            <div class="ri-sep"></div>
            <div class="ri-item">⏱ <span class="ri-val" id="ri-time">—</span>&nbsp;mins</div>
            <div class="ri-sep"></div>
            <div class="ri-item">💡 Suggest: <span class="ri-val green">₹<span id="ri-suggest">—</span></span></div>
            <button class="clear-route-btn" onclick="clearAllMarkers()">✕ Clear Route</button>
          </div>
        </div>
        <!-- ═══════════════════════ END MAP CARD ═══════════════════════ -->

        <!-- ROUTE CARD -->
        <div class="card">
          <div class="card-head">
            <div class="card-icon g">🗺️</div>
            <div class="card-title">Route Details</div>
          </div>
          <div class="card-sub-text">Set your departure and destination</div>

          <div class="g2">
            <div class="field">
              <label>Pickup Location</label>
              <div class="fi"><span class="ico">📍</span><input type="text" id="f-from"
                  placeholder="e.g. Sector 18, Noida" oninput="sync()" /></div>
            </div>
            <div class="field">
              <label>Drop-off Location</label>
              <div class="fi"><span class="ico">🏁</span><input type="text" id="f-to" placeholder="e.g. Connaught Place"
                  oninput="sync()" /></div>
            </div>
          </div>

          <div class="field">
            <label>Stops Along the Way <span
                style="text-transform:none;font-weight:400;color:var(--t3)">(optional)</span></label>
            <div class="fi"><span class="ico">🔵</span><input type="text"
                placeholder="e.g. Lajpat Nagar, INA Market — comma separated" /></div>
          </div>

          <div class="g3">
            <div class="field">
              <label>Date</label>
              <div class="fi"><span class="ico">📅</span><input type="date" id="f-date" oninput="sync()" /></div>
            </div>
            <div class="field">
              <label>Departure Time</label>
              <div class="fi"><span class="ico">🕐</span><input type="time" id="f-time" value="08:00"
                  oninput="sync()" /></div>
            </div>
            <div class="field">
              <label>Est. Duration</label>
              <div class="fi"><span class="ico">⏱</span>
                <select id="f-duration">
                  <option>~30 min</option>
                  <option>~45 min</option>
                  <option selected>~1 hr</option>
                  <option>~1.5 hrs</option>
                  <option>~2 hrs</option>
                  <option>~3+ hrs</option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <!-- VEHICLE CARD -->
        <div class="card">
          <div class="card-head">
            <div class="card-icon p">🚙</div>
            <div class="card-title">Vehicle Details</div>
          </div>
          <div class="card-sub-text">Help passengers identify your vehicle</div>

          <div class="g2">
            <div class="field">
              <label>Vehicle Type</label>
              <div class="fi"><span class="ico">🚙</span>
                <select id="f-vtype" onchange="sync()">
                  <option>Sedan</option>
                  <option>Hatchback</option>
                  <option>SUV</option>
                  <option>MUV / Van</option>
                  <option>Bike</option>
                  <option>Auto</option>
                </select>
              </div>
            </div>
            <div class="field">
              <label>Vehicle Model</label>
              <div class="fi"><span class="ico">🏷️</span><input type="text" placeholder="e.g. Swift Dzire" /></div>
            </div>
            <div class="field">
              <label>Registration No.</label>
              <div class="fi"><span class="ico">🪪</span><input type="text" placeholder="DL 01 AB 1234" /></div>
            </div>
            <div class="field">
              <label>Color</label>
              <div class="fi"><span class="ico">🎨</span><input type="text" placeholder="e.g. White, Silver" /></div>
            </div>
          </div>
        </div>

        <!-- SEATS & PRICE CARD -->
        <div class="card">
          <div class="card-head">
            <div class="card-icon a">🪑</div>
            <div class="card-title">Seats & Price</div>
          </div>
          <div class="card-sub-text">Set available seats and fare per passenger</div>

          <div class="field">
            <label>Available Seats</label>
            <div class="seat-row" id="seatRow">
              <button class="s-btn" onclick="pickSeat(this,1)" type="button">1</button>
              <button class="s-btn" onclick="pickSeat(this,2)" type="button">2</button>
              <button class="s-btn on" onclick="pickSeat(this,3)" type="button">3</button>
              <button class="s-btn" onclick="pickSeat(this,4)" type="button">4</button>
              <button class="s-btn" onclick="pickSeat(this,5)" type="button">5</button>
              <button class="s-btn" onclick="pickSeat(this,6)" type="button">6</button>
            </div>
            <p class="hint">Tap to select how many seats are available for passengers</p>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Price per Seat</label>
            <div class="price-display"><span>₹</span><span id="priceLbl">250</span></div>
            <input type="range" class="amber-r" id="priceRange" min="50" max="10000" value="250" step="10"
              oninput="document.getElementById('priceLbl').textContent=this.value;syncRange(this);calcEarn()" />
            <div style="display:flex;justify-content:space-between;font-size:11.5px;color:var(--t3);margin-top:5px">
              <span>₹50</span><span>₹10000</span>
            </div>

          </div>
        </div>

        <!-- AMENITIES CARD -->
        <div class="card">
          <div class="card-head">
            <div class="card-icon b">✨</div>
            <div class="card-title">Amenities & Preferences</div>
          </div>
          <div class="card-sub-text">Let passengers know what to expect</div>

          <div class="sec-lbl">Amenities Offered</div>
          <div class="chips">
            <div class="chip on" onclick="this.classList.toggle('on')">❄️ AC</div>
            <div class="chip" onclick="this.classList.toggle('on')">🎵 Music</div>
            <div class="chip on" onclick="this.classList.toggle('on')">🚭 No Smoking</div>
            <div class="chip" onclick="this.classList.toggle('on')">🐾 Pets OK</div>
            <div class="chip" onclick="this.classList.toggle('on')">🎒 Luggage OK</div>
            <div class="chip" onclick="this.classList.toggle('on')">🔌 USB Charger</div>
            <div class="chip" onclick="this.classList.toggle('on')">💬 Chatty</div>
            <div class="chip" onclick="this.classList.toggle('on')">🤫 Quiet Ride</div>
            <div class="chip" onclick="this.classList.toggle('on')">🧴 Sanitizer</div>
            <div class="chip" onclick="this.classList.toggle('on')">🚺 Women Only</div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Notes for Passengers</label>
            <div class="fi no-ico"><textarea
                placeholder="e.g. Leaving sharp at 8am. Can drop slightly off route if needed."></textarea></div>
          </div>

          <div class="g2" style="margin-top:12px">
            <div class="field">
              <label>Luggage Allowed</label>
              <div class="fi"><span class="ico">🧳</span>
                <select>
                  <option>Small bag</option>
                  <option>Medium bag</option>
                  <option>Large bag</option>
                  <option>No luggage</option>
                </select>
              </div>
            </div>
            <div class="field">
              <label>Gender Preference</label>
              <div class="fi"><span class="ico">👥</span>
                <select>
                  <option>Any</option>
                  <option>Men only</option>
                  <option>Women only</option>
                </select>
              </div>
            </div>
          </div>
        </div>

      </div><!-- end left col -->

      <!-- RIGHT SUMMARY COL -->
      <div class="right-col">

        <!-- SUMMARY CARD -->
        <div class="card" style="margin-bottom:0;padding-top:0;overflow:hidden">
          <div class="ticket-top-bar"></div>
          <div class="card-head">
            <div class="card-icon b">📋</div>
            <div class="card-title">Ride Summary</div>
          </div>
          <div style="margin-bottom:4px;margin-left:41px;font-size:12.5px;color:var(--t2)">Live preview of your listing
          </div>

          <div class="rvis">
            <div class="rstop">
              <div class="rdot f"></div>
              <div class="rline"></div>
              <div>
                <div class="rname" id="s-from">—</div>
                <div class="rsub">Pickup</div>
              </div>
            </div>
            <div class="rgap"></div>
            <div class="rstop">
              <div class="rdot t"></div>
              <div>
                <div class="rname" id="s-to">—</div>
                <div class="rsub">Drop-off</div>
              </div>
            </div>
          </div>

          <div class="divider" style="margin-top:0"></div>

          <div class="sum-row"><span class="sum-lbl">📅 Date & Time</span><span class="sum-val" id="s-dt">—</span></div>
          <div class="sum-row"><span class="sum-lbl">🪑 Seats</span><span class="sum-val p" id="s-seats">3</span></div>
          <div class="sum-row"><span class="sum-lbl">🚙 Vehicle</span><span class="sum-val" id="s-veh">Sedan</span>
          </div>
          <div class="sum-row"><span class="sum-lbl">💰 Per Seat</span><span class="sum-val a">₹<span
                id="s-price">250</span></span></div>
          <div class="sum-row"><span class="sum-lbl">💸 Max Earn</span><span class="sum-val g">₹<span
                id="s-earn">750</span></span></div>
          <div class="sum-row" id="s-dist-row" style="display:none"><span class="sum-lbl">📏 Distance</span><span
              class="sum-val" id="s-dist">—</span></div>

          <div class="vstrip">
            <span style="font-size:18px">✅</span>
            <p><strong>Verified only</strong> — only ID-verified passengers can book your ride.</p>
          </div>

          <button class="btn-post" onclick="postRide()">🚀 Post My Ride</button>
          <button class="btn-cancel" onclick="history.back()">Cancel</button>
        </div>

        <!-- TIPS CARD -->
        <div class="card" style="background:var(--orange-light);border-color:rgba(255,140,0,0.18);margin-bottom:0">
          <div class="card-head">
            <div class="card-icon p">💡</div>
            <div class="card-title" style="color:var(--orange)">Driver Tips</div>
          </div>
          <div style="margin-top:10px">
            <div class="tip-item"><span>🕐</span> Post rides at least 12 hrs in advance for more bookings.</div>
            <div class="tip-item"><span>📸</span> A profile photo increases bookings by 60%.</div>
            <div class="tip-item"><span>💬</span> Respond quickly to requests to maintain your rating.</div>
            <div class="tip-item"><span>⭐</span> Drivers with 4.5+ ratings get priority in search results.</div>
          </div>
        </div>

      </div><!-- end right col -->
    </div><!-- end content -->
  </div><!-- end main -->

  <!-- TOAST -->
  <div class="toast" id="toast">
    <span style="font-size:22px">🎉</span>
    <div>
      <div class="toast-t">Ride Posted!</div>
      <div class="toast-m" id="toast-m">Passengers can now find and book your ride.</div>
    </div>
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    // ══════════════════════════════════════
    //  STATE
    // ══════════════════════════════════════
    let map, pickupMarker, dropMarker, routeLine;
    let mapMode = 'click';
    let nextPin = 'pickup';
    let seats = 3;
    const DEFAULT_CENTER = [28.6139, 77.2090];

    // ══════════════════════════════════════
    //  ICONS
    // ══════════════════════════════════════
    function makeIcon(html, size, anchor) {
      return L.divIcon({ html, className: 'custom-marker', iconSize: size, iconAnchor: anchor });
    }

    const pickupIcon = makeIcon(`<div style="width:28px;height:28px;background:#FF8C00;border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:3px solid white;box-shadow:0 4px 12px rgba(255,140,0,0.45)"></div>`, [28, 28], [14, 28]);
    const dropIcon = makeIcon(`<div style="width:28px;height:28px;background:#2ECC71;border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:3px solid white;box-shadow:0 4px 12px rgba(46,204,113,0.45)"></div>`, [28, 28], [14, 28]);

    // ══════════════════════════════════════
    //  MAP INIT
    // ══════════════════════════════════════
    function initMap() {
      map = L.map('post-map', { zoomControl: false }).setView(DEFAULT_CENTER, 12);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
      }).addTo(map);

      L.control.zoom({ position: 'bottomleft' }).addTo(map);

      map.on('click', function (e) {
        if (mapMode !== 'click') return;
        // Prevent click if clicking on UI overlays
        if (e.originalEvent.target.closest('.map-overlay, .map-controls-abs')) return;

        if (nextPin === 'pickup') {
          setPickupMarker(e.latlng);
          reverseGeocode(e.latlng, 'pickup');
          nextPin = 'drop';
          updateInstruction('drop');
        } else if (nextPin === 'drop') {
          setDropMarker(e.latlng);
          reverseGeocode(e.latlng, 'drop');
          nextPin = 'done';
          updateInstruction('done');
          calculateRoute(); // Show results
        }
      });
    }

    // ══════════════════════════════════════
    //  MARKER SETTERS
    // ══════════════════════════════════════
    function setPickupMarker(latlng) {
      if (pickupMarker) map.removeLayer(pickupMarker);
      pickupMarker = L.marker(latlng, { icon: pickupIcon, draggable: true }).addTo(map);
      pickupMarker.on('dragend', () => {
        reverseGeocode(pickupMarker.getLatLng(), 'pickup');
        calculateRoute();
      });
    }

    function setDropMarker(latlng) {
      if (dropMarker) map.removeLayer(dropMarker);
      dropMarker = L.marker(latlng, { icon: dropIcon, draggable: true }).addTo(map);
      dropMarker.on('dragend', () => {
        reverseGeocode(dropMarker.getLatLng(), 'drop');
        calculateRoute();
      });
    }

    // ══════════════════════════════════════
    //  SEARCH LOGIC
    // ══════════════════════════════════════
    let debounceTimer;
    async function suggestGeo(inp, type) {
      clearTimeout(debounceTimer);
      const q = inp.value.trim();
      const dd = document.getElementById(type === 'from' ? 'dd-from' : 'dd-to');
      if (q.length < 3) { dd.style.display = 'none'; return; }

      debounceTimer = setTimeout(async () => {
        try {
          const r = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q + ', India')}&format=json&limit=4`);
          const data = await r.json();
          if (!data.length) { dd.style.display = 'none'; return; }

          dd.innerHTML = data.map(item => {
            const short = item.display_name.split(',').slice(0, 3).join(',');
            // Note: selectGeo parameters: lat, lon, type, name
            return `<div class="geo-option" onclick="selectGeo(${item.lat}, ${item.lon}, '${type}', '${short.replace(/'/g, "\\'")}')">
                        <strong>${item.display_name.split(',')[0]}</strong><br>
                        <span style="font-size:10px; color:#666">${item.display_name.split(',').slice(1, 3).join(',')}</span>
                    </div>`;
          }).join('');
          dd.style.display = 'block';
        } catch (e) { console.error("Search error", e); }
      }, 400);
    }

    function selectGeo(lat, lon, type, name) {
      const latlng = L.latLng(lat, lon);
      if (type === 'from') {
        setPickupMarker(latlng);
        document.getElementById('map-from-inp').value = name;
        document.getElementById('f-from').value = name;
        document.getElementById('dd-from').style.display = 'none';
      } else {
        setDropMarker(latlng);
        document.getElementById('map-to-inp').value = name;
        document.getElementById('f-to').value = name;
        document.getElementById('dd-to').style.display = 'none';
      }

      map.setView(latlng, 14);

      // AUTO-CALCULATE if both exist
      if (pickupMarker && dropMarker) {
        calculateRoute();
        fitRoute();
      }
      sync();
    }

    // ══════════════════════════════════════
    //  RESULTS & CALCULATION (THE KEY PART)
    // ══════════════════════════════════════
    function calculateRoute() {
      if (!pickupMarker || !dropMarker) return;

      const p1 = pickupMarker.getLatLng();
      const p2 = dropMarker.getLatLng();

      // Distance & Price Math
      const distKm = (p1.distanceTo(p2) / 1000);
      const mins = Math.round(distKm * 2.5 + 5);
      const suggest = Math.round(distKm * 8 + 50);

      // 1. Update Floating Box
      const overlay = document.getElementById('map-dist-overlay');
      if (overlay) {
        overlay.style.display = 'block';
        document.getElementById('mdo-km').textContent = distKm.toFixed(1) + ' km';
        document.getElementById('mdo-time').textContent = mins + ' min';
        document.getElementById('mdo-suggest').textContent = '₹' + suggest;
      }

      // 2. Update Bottom Bar
      const bar = document.getElementById('route-info-bar');
      if (bar) {
        bar.style.display = 'flex';
        document.getElementById('ri-km').textContent = distKm.toFixed(1);
        document.getElementById('ri-time').textContent = mins;
        document.getElementById('ri-suggest').textContent = suggest;
      }

      // 3. Update Form Slider
      const priceRange = document.getElementById('priceRange');
      if (priceRange) {
        priceRange.value = suggest;
        document.getElementById('priceLbl').textContent = suggest;
        syncRange(priceRange);
        calcEarn();
      }

      // 3b. ✅ Auto-update Est. Duration from real calculation
      updateDurationField(mins);

      // 4. Draw Line
      if (routeLine) map.removeLayer(routeLine);
      routeLine = L.polyline([p1, p2], { color: '#FF8C00', weight: 3, dashArray: '10,6' }).addTo(map);

      sync();
    }

    // ══════════════════════════════════════
    //  HELPERS
    // ══════════════════════════════════════
    function fitRoute() {
      if (pickupMarker && dropMarker) map.fitBounds([pickupMarker.getLatLng(), dropMarker.getLatLng()], { padding: [50, 50] });
    }

    function sync() {
      // 1. Sync Locations
      document.getElementById('s-from').textContent = document.getElementById('f-from').value || '—';
      document.getElementById('s-to').textContent = document.getElementById('f-to').value || '—';

      // 2. Sync Date & Time (The part you need)
      const dateVal = document.getElementById('f-date').value;
      const timeVal = document.getElementById('f-time').value;

      // Combine them for the summary display
      if (dateVal || timeVal) {
        document.getElementById('s-dt').textContent = `${dateVal} ${timeVal}`.trim();
      } else {
        document.getElementById('s-dt').textContent = '—';
      }

      // 3. Sync Price & Vehicle
      document.getElementById('s-price').textContent = document.getElementById('priceRange').value;
      const vType = document.getElementById('f-vtype');
      if (vType) {
        document.getElementById('s-veh').textContent = vType.value;
      }
    }

    function syncRange(el) {
      const val = (el.value - el.min) / (el.max - el.min) * 100;
      el.style.background = `linear-gradient(to right, #FF8C00 ${val}%, #ddd ${val}%)`;
    }

    function calcEarn() {
      const price = parseInt(document.getElementById('priceRange').value);
      document.getElementById('s-earn').textContent = price * seats;
    }

    // ── Format minutes into readable string ──────────────────────
    function formatMins(mins) {
      if (mins < 60) return `~${mins} min`;
      const h = Math.floor(mins / 60);
      const m = mins % 60;
      return m > 0 ? `~${h} hr ${m} min` : `~${h} hr`;
    }

    // ── Auto-select closest duration option OR inject real value ──
    function updateDurationField(mins) {
      const sel = document.getElementById('f-duration');
      if (!sel) return;

      const formatted = formatMins(mins);

      // Check if a matching option exists, else create one
      let found = false;
      for (let opt of sel.options) {
        opt.selected = false;
        // Match by rough range
        const v = opt.value;
        if (mins <= 35 && v === '~30 min') { opt.selected = true; found = true; break; }
        if (mins <= 52 && v === '~45 min') { opt.selected = true; found = true; break; }
        if (mins <= 70 && v === '~1 hr') { opt.selected = true; found = true; break; }
        if (mins <= 100 && v === '~1.5 hrs') { opt.selected = true; found = true; break; }
        if (mins <= 140 && v === '~2 hrs') { opt.selected = true; found = true; break; }
        if (mins > 140 && v === '~3+ hrs') { opt.selected = true; found = true; break; }
      }

      // If no existing option matched perfectly, inject a real-time option
      if (!found) {
        // Remove any previously injected dynamic option
        const existing = sel.querySelector('[data-dynamic]');
        if (existing) sel.removeChild(existing);

        const opt = document.createElement('option');
        opt.value = formatted;
        opt.textContent = formatted;
        opt.selected = true;
        opt.dataset.dynamic = '1';
        sel.insertBefore(opt, sel.firstChild);
      }
    }

    // ✅ FIXED: pickSeat was missing — seat buttons were broken
    function pickSeat(btn, n) {
      seats = n;
      // Remove 'on' from all seat buttons
      document.querySelectorAll('.s-btn').forEach(b => b.classList.remove('on'));
      // Highlight clicked button
      btn.classList.add('on');
      // Update summary panel
      document.getElementById('s-seats').textContent = n;
      // Recalculate max earnings
      calcEarn();
    }

    function setMapMode(m) {
      mapMode = m;
      document.getElementById('btn-click-mode').classList.toggle('active', m === 'click');
      document.getElementById('btn-search-mode').classList.toggle('active', m === 'search');
      document.getElementById('map-instruction').style.display = m === 'click' ? 'flex' : 'none';
      document.getElementById('map-search-row').style.display = m === 'search' ? 'flex' : 'none';
    }

    function updateInstruction(step) {
      const el = document.getElementById('instr-text');
      if (step === 'drop') el.innerHTML = 'Now click for <strong>Drop-off</strong>';
      else if (step === 'done') el.innerHTML = '✅ Route Set!';
      else el.innerHTML = 'Click for <strong>Pickup</strong>';
    }

    async function reverseGeocode(latlng, type) {
      try {
        const r = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${latlng.lat}&lon=${latlng.lng}&format=json`);
        const d = await r.json();
        const addr = d.display_name.split(',').slice(0, 2).join(', ');
        if (type === 'pickup') {
          document.getElementById('f-from').value = addr;
          document.getElementById('map-from-inp').value = addr;
        } else {
          document.getElementById('f-to').value = addr;
          document.getElementById('map-to-inp').value = addr;
        }
        sync();
      } catch (e) { }
    }
    function clearAllMarkers() {
      if (pickupMarker) {
        map.removeLayer(pickupMarker);
        pickupMarker = null;
      }

      if (dropMarker) {
        map.removeLayer(dropMarker);
        dropMarker = null;
      }

      if (routeLine) {
        map.removeLayer(routeLine);
        routeLine = null;
      }

      // Reset UI
      document.getElementById('map-from-inp').value = '';
      document.getElementById('map-to-inp').value = '';
      document.getElementById('f-from').value = '';
      document.getElementById('f-to').value = '';

      document.getElementById('route-info-bar').style.display = 'none';
      document.getElementById('map-dist-overlay').style.display = 'none';

      nextPin = 'pickup';
      updateInstruction('pickup');

      sync();
    }

    async function postRide() {
      const pickup = document.getElementById('f-from').value;
      const destination = document.getElementById('f-to').value;
      const date = document.getElementById('f-date').value;
      const time = document.getElementById('f-time').value;

      // ✅ NEW VALUES
      const fare = parseInt(document.getElementById('priceRange').value);
      const seatsValue = seats; // already defined globally

      if (!pickup || !destination || !date || !time) {
        alert("Please fill all required fields");
        return;
      }

      try {
        const token = localStorage.getItem("token");

        const res = await fetch("http://localhost:3000/api/v4/rides/post-ride", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            ...(token && { "Authorization": `Bearer ${token}` })
          },
          body: JSON.stringify({
            pickup,
            destination,
            date,
            time,
            fare,        // ✅ ADDED
            seats: seatsValue // ✅ ADDED
          })
        });

        const data = await res.json();
        console.log("Response:", data);

        if (!res.ok) {
          alert(data.message || "Error posting ride");
          return;
        }

        alert("Ride Posted Successfully 🚀");

      } catch (err) {
        console.error(err);
        alert("Error posting ride");
      }
    }

    window.onload = () => {
      initMap();

      // Set default date to today
      const dateInput = document.getElementById('f-date');
      if (!dateInput.value) {
        dateInput.valueAsDate = new Date();
      }

      // Add "change" listeners so the summary updates in real-time
      document.getElementById('f-date').addEventListener('input', sync);
      document.getElementById('f-time').addEventListener('input', sync);
      document.getElementById('f-vtype').addEventListener('change', sync);

      sync(); // Run once on load to populate defaults
      syncRange(document.getElementById('priceRange'));
    };
  </script>


  <script>
    // ── Dynamic sidebar user info ──
    (async () => {
      const token = localStorage.getItem("token");
      if (!token) return;
      try {
        const res = await fetch("http://localhost:3000/api/v4/user/me", {
          headers: { Authorization: `Bearer ${token}` }
        });
        const data = await res.json();
        if (data.success) {
          const u = data.user;
          document.getElementById("sb-name").textContent = u.name || "User";
          document.getElementById("sb-role").textContent = u.role || "Passenger";
          const initials = u.name.split(" ").map(n => n[0]).join("").toUpperCase().slice(0, 2);
          document.getElementById("sb-avatar").textContent = initials;
        }
      } catch (e) { /* silent */ }
    })();
  </script>

</body>

</html>