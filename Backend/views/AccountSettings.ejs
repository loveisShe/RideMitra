<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ride मित्र — Account Settings</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Rozha+One&family=Noto+Sans+Devanagari:wght@700;900&display=swap"
        rel="stylesheet">
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #FAFAF8;
            --surface: #FFFFFF;
            --surface2: #F5F3EE;
            --border: #E8E5DF;
            --accent: #FF8C00;
            --accent2: #E07000;
            --green: #2ECC71;
            --red: #E74C3C;
            --yellow: #F39C12;
            --text: #1A1A2E;
            --muted: #8A8A9A;
            --card-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
            --card-shadow-hover: 0 8px 32px rgba(0, 0, 0, 0.11);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ── Sidebar ── */
        .sidebar {
            width: 240px;
            min-height: 100vh;
            background: rgba(255, 255, 255, 0.82);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 28px 0;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            z-index: 100;
            box-shadow: 2px 0 24px rgba(0, 0, 0, 0.04);
        }

        /* UPDATED LOGO STYLE */
        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 24px 32px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800;
            font-size: 20px;
            color: var(--text);
            letter-spacing: -0.3px;
        }

        .logo .hindi {
            font-family: 'Rozha One', 'Noto Sans Devanagari', serif;
            font-weight: 900;
            color: var(--accent);
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--accent), #FF6B00);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            box-shadow: 0 4px 12px rgba(255, 140, 0, 0.3);
        }

        .nav-section {
            padding: 0 12px;
            margin-bottom: 24px;
        }

        .nav-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            color: var(--muted);
            text-transform: uppercase;
            padding: 0 12px 10px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 14px;
            color: var(--muted);
            font-weight: 500;
            margin-bottom: 2px;
            text-decoration: none;
        }

        .nav-item:hover {
            background: var(--surface2);
            color: var(--text);
        }

        .nav-item.active {
            background: linear-gradient(90deg, rgba(255, 140, 0, 0.12), rgba(255, 140, 0, 0.05));
            color: var(--accent);
            border: 1px solid rgba(255, 140, 0, 0.2);
            font-weight: 600;
        }

        .nav-item .icon {
            font-size: 16px;
            width: 20px;
            text-align: center;
        }

        .badge {
            margin-left: auto;
            background: var(--accent);
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 20px;
        }

        .sidebar-cta {
            margin: 0 12px 24px;
        }

        .cta-btn-sidebar {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            padding: 12px 16px;
            border-radius: 14px;
            border: none;
            background: linear-gradient(135deg, var(--accent), #FF6B00);
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s;
            box-shadow: 0 4px 20px rgba(255, 140, 0, 0.35);
            letter-spacing: 0.3px;
        }

        .cta-btn-sidebar:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .cta-btn-sidebar:active {
            transform: translateY(0);
        }

        .sidebar-bottom {
            margin-top: auto;
            padding: 0 12px;
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            background: var(--surface2);
            border-radius: 14px;
            border: 1px solid var(--border);
            box-shadow: var(--card-shadow);
        }

        .avatar {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--accent), #FF6B00);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 13px;
            color: #fff;
        }

        .user-info {
            flex: 1;
        }

        .user-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }

        .user-role {
            font-size: 11px;
            color: var(--muted);
        }

        /* ── Main ── */
        .main {
            margin-left: 240px;
            flex: 1;
            padding: 32px;
            max-width: calc(100vw - 240px);
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 36px;
        }

        .page-title {
            font-family: 'Rozha One', serif;
            font-size: 28px;
            font-weight: 400;
            color: var(--text);
            letter-spacing: 0.3px;
        }

        .breadcrumb {
            font-size: 12px;
            color: var(--muted);
            margin-top: 2px;
            font-weight: 500;
        }

        .breadcrumb span {
            color: var(--accent);
            font-weight: 600;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .search-box {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 9px 14px;
            font-size: 13px;
            color: var(--muted);
            width: 220px;
            box-shadow: var(--card-shadow);
        }

        .notif-btn {
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            position: relative;
            font-size: 16px;
            box-shadow: var(--card-shadow);
        }

        .notif-dot {
            position: absolute;
            top: 8px;
            right: 8px;
            width: 7px;
            height: 7px;
            background: var(--red);
            border-radius: 50%;
            border: 1px solid var(--bg);
        }

        /* ── Greeting Banner ── */
        .greeting-banner {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 28px 32px;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
            animation: fadeUp 0.5s ease both;
            box-shadow: var(--card-shadow);
        }

        .greeting-banner::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, rgba(255, 140, 0, 0.06) 0%, rgba(255, 107, 0, 0.03) 50%, transparent 80%);
            pointer-events: none;
        }

        .greeting-bg-blob {
            position: absolute;
            right: -60px;
            top: -60px;
            width: 260px;
            height: 260px;
            background: radial-gradient(circle, rgba(255, 140, 0, 0.1), transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .greeting-text .hello {
            font-size: 13px;
            color: var(--muted);
            margin-bottom: 4px;
            font-weight: 500;
        }

        .greeting-text h2 {
            font-family: 'Rozha One', serif;
            font-size: 24px;
            font-weight: 400;
            margin-bottom: 6px;
            color: var(--text);
            letter-spacing: 0.3px;
        }

        .greeting-text p {
            font-size: 13px;
            color: var(--muted);
            line-height: 1.6;
            font-weight: 400;
        }

        .greeting-stats {
            display: flex;
            gap: 32px;
            position: relative;
            z-index: 1;
        }

        .greet-stat {
            text-align: center;
        }

        .greet-stat-val {
            font-family: 'Rozha One', serif;
            font-size: 24px;
            font-weight: 400;
            margin-bottom: 2px;
        }

        .greet-stat-label {
            font-size: 11px;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 600;
        }

        .greet-divider {
            width: 1px;
            background: var(--border);
            height: 40px;
            align-self: center;
        }

        /* ── Action Cards Grid ── */
        .action-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 24px;
        }

        .action-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 32px;
            position: relative;
            overflow: hidden;
            transition: transform 0.22s, box-shadow 0.22s, border-color 0.2s;
            animation: fadeUp 0.5s ease both;
            box-shadow: var(--card-shadow);
        }

        .action-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--card-shadow-hover);
        }

        .action-card.search-card {
            animation-delay: 0.1s;
        }

        .action-card.sell-card {
            animation-delay: 0.18s;
        }

        .action-card.search-card:hover {
            border-color: rgba(255, 140, 0, 0.35);
        }

        .action-card.sell-card:hover {
            border-color: rgba(46, 204, 113, 0.35);
        }

        .action-card.search-card::before {
            content: '';
            position: absolute;
            right: -40px;
            bottom: -40px;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(255, 140, 0, 0.08), transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .action-card.sell-card::before {
            content: '';
            position: absolute;
            right: -40px;
            bottom: -40px;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(46, 204, 113, 0.08), transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .action-card-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin-bottom: 20px;
        }

        .search-card .action-card-icon {
            background: rgba(255, 140, 0, 0.1);
        }

        .sell-card .action-card-icon {
            background: rgba(46, 204, 113, 0.1);
        }

        .action-card-title {
            font-family: 'Rozha One', serif;
            font-size: 22px;
            font-weight: 400;
            margin-bottom: 6px;
            color: var(--text);
            letter-spacing: 0.3px;
            line-height: 1.4;
        }

        .action-card-sub {
            font-size: 13px;
            color: var(--muted);
            line-height: 1.7;
            margin-bottom: 24px;
            font-weight: 400;
        }

        .search-row {
            display: flex;
            gap: 10px;
            align-items: stretch;
        }

        .ride-input-wrap {
            flex: 1;
            position: relative;
        }

        .ride-input-wrap .input-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 14px;
            color: var(--muted);
            pointer-events: none;
        }

        .ride-input {
            width: 100%;
            background: var(--surface2);
            border: 1.5px solid var(--border);
            border-radius: 12px;
            padding: 12px 14px 12px 38px;
            color: var(--text);
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .ride-input::placeholder {
            color: var(--muted);
        }

        .ride-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(255, 140, 0, 0.12);
        }

        .btn-search {
            padding: 12px 22px;
            border-radius: 12px;
            border: none;
            background: linear-gradient(135deg, var(--accent), #FF6B00);
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s;
            white-space: nowrap;
            box-shadow: 0 4px 16px rgba(255, 140, 0, 0.3);
        }

        .btn-search:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .btn-search:active {
            transform: translateY(0);
        }

        .quick-chips {
            display: flex;
            gap: 8px;
            margin-top: 14px;
            flex-wrap: wrap;
        }

        .chip {
            font-size: 12px;
            color: var(--muted);
            background: var(--surface2);
            border: 1.5px solid var(--border);
            padding: 5px 12px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.2s;
            font-weight: 500;
        }

        .chip:hover {
            color: var(--accent);
            border-color: rgba(255, 140, 0, 0.4);
            background: rgba(255, 140, 0, 0.05);
        }

        .feature-pills {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 24px;
        }

        .feature-pill {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            color: var(--muted);
            font-weight: 400;
        }

        .feature-pill-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--green);
            flex-shrink: 0;
        }

        .btn-post {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 13px 28px;
            border-radius: 14px;
            border: none;
            background: linear-gradient(135deg, var(--green), #27AE60);
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s;
            box-shadow: 0 4px 20px rgba(46, 204, 113, 0.3);
            letter-spacing: 0.3px;
        }

        .btn-post:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .btn-post:active {
            transform: translateY(0);
        }

        /* ── Recent Rides Table ── */
        .table-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 24px;
            animation: fadeUp 0.5s ease 0.3s both;
            box-shadow: var(--card-shadow);
        }

        .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 22px;
        }

        .card-title {
            font-family: 'Rozha One', serif;
            font-weight: 400;
            font-size: 17px;
            color: var(--text);
            letter-spacing: 0.2px;
        }

        .card-sub {
            font-size: 11px;
            color: var(--muted);
            margin-top: 3px;
            font-weight: 500;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            font-size: 11px;
            color: var(--muted);
            font-weight: 700;
            text-align: left;
            padding: 0 0 12px;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            border-bottom: 1.5px solid var(--border);
        }

        td {
            padding: 12px 0;
            font-size: 13px;
            border-bottom: 1px solid rgba(232, 229, 223, 0.7);
            vertical-align: middle;
        }

        tr:last-child td {
            border-bottom: none;
        }

        .rider-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .rider-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
            flex-shrink: 0;
            color: #fff;
        }

        .rider-name {
            font-weight: 600;
            font-size: 13px;
            color: var(--text);
        }

        .rider-id {
            font-size: 11px;
            color: var(--muted);
            font-weight: 500;
        }

        .status-badge {
            font-size: 11px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 20px;
            display: inline-block;
            letter-spacing: 0.2px;
        }

        .status-active {
            background: rgba(46, 204, 113, 0.1);
            color: #27AE60;
        }

        .status-pending {
            background: rgba(243, 156, 18, 0.12);
            color: #E67E22;
        }

        .status-completed {
            background: rgba(255, 140, 0, 0.1);
            color: var(--accent);
        }

        .status-cancelled {
            background: rgba(231, 76, 60, 0.1);
            color: var(--red);
        }

        .stars {
            color: var(--yellow);
            font-size: 11px;
            letter-spacing: 1px;
        }

        /* ── Profile Snapshot ── */
        .profile-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 28px;
            animation: fadeUp 0.5s ease 0.3s both;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            box-shadow: var(--card-shadow);
        }

        .profile-avatar-lg {
            width: 72px;
            height: 72px;
            background: linear-gradient(135deg, var(--accent), #FF6B00);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 22px;
            margin-bottom: 14px;
            box-shadow: 0 0 0 5px rgba(255, 140, 0, 0.12), 0 4px 20px rgba(255, 140, 0, 0.2);
            color: #fff;
        }

        .profile-name {
            font-family: 'Rozha One', serif;
            font-size: 20px;
            font-weight: 400;
            margin-bottom: 3px;
            color: var(--text);
            letter-spacing: 0.3px;
        }

        .profile-email {
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 20px;
            font-weight: 500;
        }

        .profile-stats {
            display: flex;
            gap: 0;
            width: 100%;
            border: 1.5px solid var(--border);
            border-radius: 14px;
            overflow: hidden;
            margin-bottom: 20px;
            background: var(--surface2);
        }

        .p-stat {
            flex: 1;
            padding: 14px 10px;
            text-align: center;
            border-right: 1.5px solid var(--border);
        }

        .p-stat:last-child {
            border-right: none;
        }

        .p-stat-val {
            font-family: 'Rozha One', serif;
            font-size: 20px;
            font-weight: 400;
            margin-bottom: 3px;
        }

        .p-stat-label {
            font-size: 10px;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 700;
        }

        .btn-edit-profile {
            width: 100%;
            padding: 11px;
            border-radius: 12px;
            border: 1.5px solid var(--border);
            background: var(--surface2);
            color: var(--text);
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: border-color 0.2s, background 0.2s, color 0.2s;
        }

        .btn-edit-profile:hover {
            border-color: var(--accent);
            background: rgba(255, 140, 0, 0.05);
            color: var(--accent);
        }

        /* ── Layout helpers ── */
        .bottom-row {
            display: grid;
            grid-template-columns: 1.4fr 1fr;
            gap: 20px;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(18px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ── Profile Grid ── */
        .profile-grid {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 24px;
            margin-bottom: 24px;
        }

        /* ── Left: Overview Card ── */
        .overview-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 32px 24px;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            animation: fadeUp 0.5s ease both;
            box-shadow: var(--card-shadow);
            position: relative;
            overflow: hidden;
        }

        .overview-card::before {
            content: '';
            position: absolute;
            top: -40px;
            right: -40px;
            width: 180px;
            height: 180px;
            background: radial-gradient(circle, rgba(255, 140, 0, 0.08), transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .avatar-wrap {
            position: relative;
            margin-bottom: 18px;
        }

        .profile-avatar-xl {
            width: 88px;
            height: 88px;
            background: linear-gradient(135deg, var(--accent), #FF6B00);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 26px;
            color: #fff;
            box-shadow: 0 0 0 6px rgba(255, 140, 0, 0.12), 0 6px 24px rgba(255, 140, 0, 0.25);
            position: relative;
            z-index: 1;
        }

        .avatar-ring {
            position: absolute;
            inset: -6px;
            border-radius: 50%;
            border: 1.5px dashed rgba(255, 140, 0, 0.3);
            animation: spin 18s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .change-photo-btn {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 28px;
            height: 28px;
            background: var(--accent);
            border: 2px solid var(--surface);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 13px;
            z-index: 2;
            transition: transform 0.2s, background 0.2s;
        }

        .change-photo-btn:hover {
            transform: scale(1.15);
            background: var(--accent2);
        }

        .ov-name {
            font-family: 'Rozha One', serif;
            font-size: 22px;
            font-weight: 400;
            color: var(--text);
            margin-bottom: 4px;
            letter-spacing: 0.3px;
        }

        .ov-role {
            font-size: 12px;
            color: var(--muted);
            font-weight: 500;
            margin-bottom: 6px;
        }

        .verified-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 11px;
            font-weight: 700;
            color: #27AE60;
            background: rgba(46, 204, 113, 0.1);
            border: 1px solid rgba(46, 204, 113, 0.2);
            padding: 3px 10px;
            border-radius: 20px;
            margin-bottom: 24px;
        }

        .ov-divider {
            width: 100%;
            height: 1px;
            background: var(--border);
            margin-bottom: 20px;
        }

        .ov-stats {
            width: 100%;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 24px;
        }

        .ov-stat {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 14px 10px;
            text-align: center;
        }

        .ov-stat-val {
            font-family: 'Rozha One', serif;
            font-size: 20px;
            font-weight: 400;
            color: var(--text);
            margin-bottom: 3px;
        }

        .ov-stat-val.accent {
            color: var(--accent);
        }

        .ov-stat-label {
            font-size: 10px;
            color: var(--muted);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-change-photo {
            width: 100%;
            padding: 10px;
            border-radius: 12px;
            border: 1.5px dashed rgba(255, 140, 0, 0.35);
            background: rgba(255, 140, 0, 0.04);
            color: var(--accent);
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s, border-color 0.2s;
            letter-spacing: 0.2px;
        }

        .btn-change-photo:hover {
            background: rgba(255, 140, 0, 0.09);
            border-color: rgba(255, 140, 0, 0.6);
        }

        /* ── Right: Info Card ── */
        .info-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 32px;
            animation: fadeUp 0.5s ease 0.1s both;
            box-shadow: var(--card-shadow);
        }

        .card-heading {
            font-family: 'Rozha One', serif;
            font-size: 19px;
            font-weight: 400;
            color: var(--text);
            letter-spacing: 0.3px;
            margin-bottom: 4px;
        }

        .card-sub-text {
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 28px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 18px;
            margin-bottom: 18px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 7px;
        }

        .form-group.full {
            grid-column: 1 / -1;
        }

        .form-label {
            font-size: 12px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .input-wrap {
            position: relative;
        }

        .input-icon-left {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 14px;
            pointer-events: none;
            color: var(--muted);
        }

        .ride-input:disabled {
            opacity: 0.55;
            cursor: not-allowed;
            background: var(--border);
        }

        .disabled-tag {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            background: var(--border);
            padding: 2px 7px;
            border-radius: 20px;
            letter-spacing: 0.3px;
            text-transform: uppercase;
        }

        .form-divider {
            height: 1px;
            background: var(--border);
            margin: 26px 0;
        }

        .security-section-title {
            font-family: 'Rozha One', serif;
            font-size: 16px;
            font-weight: 400;
            color: var(--text);
            margin-bottom: 16px;
            letter-spacing: 0.2px;
        }

        .security-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 14px;
            margin-bottom: 10px;
        }

        .security-row-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .security-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }

        .sec-title {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }

        .sec-sub {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px;
        }

        .btn-sec-action {
            font-size: 12px;
            font-weight: 600;
            color: var(--accent);
            background: rgba(255, 140, 0, 0.08);
            border: 1px solid rgba(255, 140, 0, 0.2);
            padding: 6px 14px;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .btn-sec-action:hover {
            background: rgba(255, 140, 0, 0.16);
        }

        /* ── Action Bar ── */
        .action-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 28px 32px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 20px;
            animation: fadeUp 0.5s ease 0.22s both;
            box-shadow: var(--card-shadow);
        }

        .action-row-label {
            font-size: 13px;
            color: var(--muted);
        }

        .action-row-hint {
            font-size: 11px;
            color: var(--muted);
            opacity: 0.7;
            margin-top: 3px;
        }

        .btn-group {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn-save {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            border-radius: 14px;
            border: none;
            background: linear-gradient(135deg, var(--accent), #FF6B00);
            color: #fff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s;
            box-shadow: 0 4px 20px rgba(255, 140, 0, 0.35);
            letter-spacing: 0.3px;
        }

        .btn-save:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .btn-delete {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 12px 22px;
            border-radius: 14px;
            border: 1.5px solid rgba(231, 76, 60, 0.3);
            background: rgba(231, 76, 60, 0.05);
            color: var(--red);
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s, border-color 0.2s, transform 0.15s;
        }

        .btn-delete:hover {
            background: rgba(231, 76, 60, 0.1);
            border-color: rgba(231, 76, 60, 0.55);
            transform: translateY(-1px);
        }
    </style>
</head>

<body>


    <aside class="sidebar">
        <div class="logo">
            <div class="logo-icon">🚗</div>
            Ride <span class="hindi">मित्र</span>
        </div>

        <div class="sidebar-cta">
            <button class="cta-btn-sidebar"><a href="/post-ride">＋ &nbsp;Post a Ride</a></button>
        </div>

        <div class="nav-section">
            <div class="nav-label">Main</div>
            <a href="/dashboard">
                <div class="nav-item"><span class="icon">📊</span> Dashboard</div>
            </a>
            <a href="/find-ride">
                <div class="nav-item"><span class="icon">🗺️</span> Find a Ride</div>
            </a>
            <a href="/post-ride">
                <div class="nav-item"><span class="icon">📅</span> My Rides</div>
            </a>
            <div class="nav-item"><span class="icon">💰</span> Payments</div>
        </div>

        <div class="nav-section">
            <div class="nav-label">Account</div>
            <a href="/notifications">
                <div class="nav-item"><span class="icon">🔔</span> Notifications</div>
            </a>
            <a href="/account-settings">
                <div class="nav-item active"><span class="icon">⚙️</span> Settings</div>
            </a>
            <a href="/">
                <div class="nav-item"><span class="icon">🔐</span> Logout</div>
            </a>

        </div>


        <div class="sidebar-bottom">
            <div class="user-card">
                <div class="avatar">--</div>
                <div class="user-info">
                    <div class="user-name">Loading...</div>
                    <div class="user-role">Passenger</div>
                </div>
                <span style="color:var(--muted); font-size:14px; cursor:pointer;">⋯</span>
            </div>
        </div>
    </aside>

    <main class="main">

        <div class="topbar">
            <div class="page-title">My Profile</div>
            <div class="breadcrumb">Dashboard &rsaquo; <span>Account Settings</span></div>
        </div>

        <div class="profile-grid">

            <!-- Left: Overview -->
            <div class="overview-card">
                <div class="avatar-wrap">
                    <div class="avatar-ring"></div>
                    <div class="profile-avatar-xl">--</div>
                    <div class="change-photo-btn" title="Change photo">📷</div>
                </div>
                <div class="ov-name">Loading...</div>
                <div class="ov-role">Passenger</div>
                <div class="verified-pill">✓ &nbsp;Verified Account</div>
                <div class="ov-divider"></div>
                <div class="ov-stats">
                    <div class="ov-stat">
                        <div class="ov-stat-val accent">42</div>
                        <div class="ov-stat-label">Rides</div>
                    </div>
                    <div class="ov-stat">
                        <div class="ov-stat-val" style="color:var(--yellow);">4.8 ★</div>
                        <div class="ov-stat-label">Rating</div>
                    </div>
                    <div class="ov-stat">
                        <div class="ov-stat-val" style="color:var(--green);">₹3.2k</div>
                        <div class="ov-stat-label">Saved</div>
                    </div>
                    <div class="ov-stat">
                        <div class="ov-stat-val">6</div>
                        <div class="ov-stat-label">Reviews</div>
                    </div>
                </div>
                <button class="btn-change-photo">📷 &nbsp; Change Photo</button>
            </div>

            <!-- Right: Personal Info -->
            <div class="info-card">
                <div class="card-heading">Personal Information</div>
                <div class="card-sub-text">Update your profile details and manage your account.</div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Full Name</label>
                        <div class="input-wrap">
                            <span class="input-icon-left">👤</span>
                            <input class="ride-input" type="text" value="" placeholder="Your full name"
                                disabled />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Phone Number</label>
                        <div class="input-wrap">
                            <span class="input-icon-left">📱</span>
                            <input class="ride-input" type="tel" value="" disabled />
                        </div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Email Address</label>
                        <div class="input-wrap">
                            <span class="input-icon-left">✉️</span>
                            <input class="ride-input" type="email" value="" disabled />
                            <span class="disabled-tag">Locked</span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">City</label>
                        <div class="input-wrap">
                            <span class="input-icon-left">📍</span>
                            <input class="ride-input" type="text" value="" disabled />
                        </div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group full">
                        <label class="form-label">Bio <span
                                style="color:var(--muted);font-size:10px;text-transform:none;letter-spacing:0;font-weight:400;">(optional)</span></label>
                        <div class="input-wrap">
                            <span class="input-icon-left" style="top:16px;transform:none;">✏️</span>
                            <textarea class="ride-input" rows="3" placeholder="A short intro visible to fellow riders…"
                                style="resize:vertical;padding-top:12px;padding-bottom:12px;line-height:1.6;"
                                disabled></textarea>
                        </div>
                    </div>
                </div>

                <div class="form-divider"></div>
                <div class="security-section-title">Security</div>

                <div class="security-row">
                    <div class="security-row-left">
                        <div class="security-icon" style="background:rgba(255,140,0,0.1);">🔑</div>
                        <div>
                            <div class="sec-title">Password</div>
                            <div class="sec-sub">Last changed 3 months ago</div>
                        </div>
                    </div>
                    <button class="btn-sec-action">Change</button>
                </div>

                <div class="security-row">
                    <div class="security-row-left">
                        <div class="security-icon" style="background:rgba(46,204,113,0.1);">🛡️</div>
                        <div>
                            <div class="sec-title">Two-Factor Authentication</div>
                            <div class="sec-sub">Not enabled — secure your account</div>
                        </div>
                    </div>
                    <button class="btn-sec-action">Enable</button>
                </div>
            </div>
        </div>

        <div class="action-row">
            <div class="action-row-left">
                <div class="action-row-label">Ready to update your profile?</div>
                <div class="action-row-hint">Changes will be visible to other users immediately.</div>
            </div>
            <div class="btn-group">
                <button class="btn-delete">🗑 &nbsp; Delete Account</button>
                <button class="btn-save" id="editBtn">&nbsp;✏️ Edit</button>
            </div>
        </div>

        <!-- Hidden file input for photo upload -->
        <input type="file" id="photoFileInput" accept="image/*" style="display:none;" />

        <script>
        let isEditing = false;
        let currentUserId = null;
        let selectedPhotoFile = null;   // ← holds the chosen image file

        const token = localStorage.getItem("token");
        const editBtn  = document.getElementById("editBtn");
        const deleteBtn = document.querySelector(".btn-delete");
        const inputs   = document.querySelectorAll(".ride-input:not([type='email'])");
        const fileInput = document.getElementById("photoFileInput");

        // ── Load user profile on page load ──────────────────────
        async function initPage() {
            try {
                const response = await fetch('http://localhost:3000/api/v4/user/me', {
                    headers: { Authorization: `Bearer ${token}` }
                });
                const data = await response.json();

                if (data.success) {
                    const user = data.user;
                    currentUserId = user.id;   // ✅ Prisma returns id (integer), not _id

                    document.querySelector('input[placeholder="Your full name"]').value = user.name  || "";
                    document.querySelector('input[type="tel"]').value                   = user.phone || "";
                    document.querySelector('input[type="email"]').value                 = user.email || "";
                    document.querySelector('textarea').value                            = user.bio   || "";

                    const cityInput = document.querySelectorAll('.ride-input')[3];
                    if (cityInput) cityInput.value = user.city || "";

                    document.querySelector('.ov-name').innerText = user.name;
                    document.querySelectorAll('.user-name').forEach(el => el.innerText = user.name);

                    // Show profile picture if it exists, else show initials
                    const avatarEl = document.querySelector('.profile-avatar-xl');
                    if (user.profilePicture) {
                        avatarEl.innerHTML = `<img src="${user.profilePicture}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />`;
                    } else {
                        const initials = user.name.split(' ').map(n => n[0]).join('').toUpperCase();
                        avatarEl.innerText = initials;
                        document.querySelectorAll('.avatar').forEach(el => el.innerText = initials);
                    }
                } else {
                    window.location.href = "/";
                }
            } catch (err) {
                console.error("Failed to load profile:", err);
            }
        }

        // ── Change Photo — both buttons trigger file picker ──────
        document.querySelector('.btn-change-photo').addEventListener('click', () => fileInput.click());
        document.querySelector('.change-photo-btn').addEventListener('click', () => fileInput.click());

        // ── When user picks a file — show preview immediately ────
        fileInput.addEventListener('change', () => {
            const file = fileInput.files[0];
            if (!file) return;
            selectedPhotoFile = file;

            const reader = new FileReader();
            reader.onload = (e) => {
                const avatarEl = document.querySelector('.profile-avatar-xl');
                avatarEl.innerHTML = `<img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />`;
            };
            reader.readAsDataURL(file);

            // Auto-upload photo right away
            uploadPhoto(file);
        });

        // ── Upload photo to backend via FormData ─────────────────
        async function uploadPhoto(file) {
            const formData = new FormData();
            formData.append('profilePicture', file);

            try {
                const response = await fetch(`http://localhost:3000/api/v4/user/update-profile`, {
                    method: 'PUT',
                    headers: { Authorization: `Bearer ${token}` },
                    body: formData   // ✅ multipart/form-data — DO NOT set Content-Type manually
                });
                const result = await response.json();
                if (result.success) {
                    alert("Profile picture updated! ✅");
                } else {
                    alert("Photo upload failed: " + result.message);
                }
            } catch (err) {
                console.error("Photo upload error:", err);
                alert("Server error during photo upload.");
            }
        }

        // ── Edit / Save profile text fields ──────────────────────
        editBtn.addEventListener("click", async () => {
            if (!isEditing) {
                isEditing = true;
                inputs.forEach(input => input.disabled = false);
                editBtn.innerHTML = "💾 Save Changes";
            } else {
                const cityInput = document.querySelectorAll('.ride-input')[3];
                const updatedData = {
                    name:  document.querySelector('input[placeholder="Your full name"]').value,
                    phone: document.querySelector('input[type="tel"]').value,
                    city:  cityInput ? cityInput.value : "",
                    bio:   document.querySelector('textarea').value
                };

                try {
                    const response = await fetch(`http://localhost:3000/api/v4/user/update-profile`, {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/json',
                            Authorization: `Bearer ${token}`
                        },
                        body: JSON.stringify(updatedData)
                    });
                    const result = await response.json();

                    if (result.success) {
                        alert("Profile updated successfully! ✅");
                        isEditing = false;
                        inputs.forEach(input => input.disabled = true);
                        editBtn.innerHTML = "✏️ Edit";
                        document.querySelector('.ov-name').innerText = updatedData.name;
                        document.querySelectorAll('.user-name').forEach(el => el.innerText = updatedData.name);
                    } else {
                        alert("Update failed: " + result.message);
                    }
                } catch (error) {
                    console.error("Error:", error);
                    alert("Server error. Please try again.");
                }
            }
        });

        // ── Delete Account ────────────────────────────────────────
        deleteBtn.addEventListener("click", async () => {
            if (confirm("Permanently delete your Ride मित्र account?")) {
                try {
                    const response = await fetch(`http://localhost:3000/api/v4/user/delete-user/${currentUserId}`, {
                        method: 'DELETE',
                        headers: { Authorization: `Bearer ${token}` }
                    });
                    const result = await response.json();
                    if (result.success) {
                        localStorage.removeItem("token");
                        window.location.href = "/";
                    }
                } catch (err) {
                    console.error("Delete failed:", err);
                }
            }
        });

        window.onload = initPage;
        </script>

    </main>
</body>

</html>