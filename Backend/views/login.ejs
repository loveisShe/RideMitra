        </div>
      </div>

      <!-- ── SIGN UP ── -->
      <div class="modal-panel" id="mpanel-signup">
        <div class="modal-heading">Join Mitra Ride ✦</div>
        <div class="modal-sub">Create your account and start your journey today.</div>

        <div id="google-btn-signup" class="btn-google-container"></div>


        <div class="or-divider">
          <div class="or-line"></div>
          <span class="or-text">or fill in your details</span>
          <div class="or-line"></div>
        </div>

        <form onsubmit="handleSignup(event)">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">First Name</label>
              <div class="input-wrap">
                <span class="input-icon">👤</span>
                <input id="signup-firstname" type="text" class="form-input" placeholder="Alex" required />
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Last Name</label>
              <div class="input-wrap">
                <span class="input-icon">👤</span>
                <input id="signup-lastname" type="text" class="form-input" placeholder="Chen" required />
              </div>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Email Address</label>
            <div class="input-wrap">
              <span class="input-icon">✉️</span>
              <input id="signup-email" type="email" class="form-input" placeholder="you@example.com" required />
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Password</label>
            <div class="input-wrap">
              <span class="input-icon">🔒</span>
              <input type="password" class="form-input" id="signup-password" placeholder="Create a strong password"
                oninput="checkStrength(this)" required />
              <button type="button" class="pwd-eye" onclick="togglePwd('signup-password', this)">👁</button>
