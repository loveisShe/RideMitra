  <script src="https://accounts.google.com/gsi/client" async defer></script>
  <script>
    function openModal(tab) {
      document.body.classList.add('modal-open');
      document.getElementById('modal-overlay').classList.add('visible');
      switchModalTab(tab || 'signin');
    }

    function closeModal() {
      document.body.classList.remove('modal-open');
      document.getElementById('modal-overlay').classList.remove('visible');
    }

    function handleOverlayClick(e) {
      if (e.target === document.getElementById('modal-overlay')) closeModal();
    }

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeModal();
    });

    function switchModalTab(tab) {
      ['signin', 'signup'].forEach(t => {
        document.getElementById('mpanel-' + t).classList.toggle('active', t === tab);
        document.getElementById('mtab-' + t).classList.toggle('active', t === tab);
      });
    }

    function togglePwd(id, btn) {
      const input = document.getElementById(id);
      input.type = input.type === 'password' ? 'text' : 'password';
      btn.textContent = input.type === 'password' ? '👁' : '🙈';
    }

    function checkStrength(input) {
      const v = input.value;
      let score = 0;
      if (v.length >= 8) score++;
      if (/[A-Z]/.test(v)) score++;
      if (/[0-9]/.test(v)) score++;
      if (/[^A-Za-z0-9]/.test(v)) score++;
      const cls = ['', 'weak', 'medium', 'medium', 'strong'];
      ['sb1', 'sb2', 'sb3', 'sb4'].forEach((id, i) => {
        const bar = document.getElementById(id);
        bar.className = 'pwd-bar';
        if (i < score) bar.classList.add(cls[score]);
      });
    }

    function selectType(card) {
      card.closest('.type-cards').querySelectorAll('.type-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
    }

    window.addEventListener('scroll', () => {
      document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 20);
    });

    /* — Authentication Logic — */

    // Safari-safe token storage: falls back to sessionStorage if localStorage is blocked
    function saveToken(token) {
      try { localStorage.setItem("token", token); } catch(e) {}
      try { sessionStorage.setItem("token", token); } catch(e) {}
    }

    async function handleSignup(event) {
      event.preventDefault();

      const firstName = document.getElementById("signup-firstname").value;
      const lastName = document.getElementById("signup-lastname").value;

      const name = firstName + " " + lastName;

      const email = document.getElementById("signup-email").value;
      const password = document.getElementById("signup-password").value;

      const response = await fetch("/api/v4/user/register", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({ name, email, password, role: "Passenger" })
      });

      const result = await response.json();
      alert(result.message);

      if (response.ok) {
        saveToken(result.token);
        window.location.href = '/dashboard';
      }
    }
    async function handleLogin(event) {
      event.preventDefault();

      const email = document.getElementById('login-email').value;
      const password = document.getElementById('login-password').value;

      const response = await fetch('/api/v4/user/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ email, password })
      });

      const result = await response.json();

      if (response.ok) {
        saveToken(result.token);
        window.location.href = "/dashboard";
      } else {
        alert(result.message);
      }
    }

    // onGoogleLibraryLoad is called by GSI after the script fully loads — no race condition
    window.onGoogleLibraryLoad = function () {
      google.accounts.id.initialize({
        client_id: '173008253506-rk60rbs422nng2hvuis23addl1378k84.apps.googleusercontent.com',
        callback: (response) => {
          // response.credential is the ID token — what the backend verifies
          handleGoogleAuth(response.credential);
        },
        ux_mode: 'popup'
      });

      // Render real Google-styled buttons into each container div
      // renderButton() opens a proper popup — unlike prompt() which browsers block inside modals
      ['google-btn-signin', 'google-btn-signup'].forEach(id => {
        const el = document.getElementById(id);
        if (el) {
          google.accounts.id.renderButton(el, {
            theme: 'outline',
            size: 'large',
            width: el.offsetWidth || 340,
            text: 'continue_with',
            shape: 'rectangular',
            logo_alignment: 'left'
          });
        }
      });
    };

    async function handleGoogleAuth(idToken) {
      try {
        const res = await fetch("/api/v4/user/google-login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ token: idToken })
        });

        const result = await res.json();
        if (res.ok) {
          saveToken(result.token);
          window.location.href = "/dashboard";
        } else {
          alert(result.message || "Google login failed. Please try email login.");
        }
      } catch (err) {
        console.error("Google Login Error:", err);
        alert("Google login failed. Please try email login.");
      }
    }
  </script>
</body>

</html>